#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
root="$(cd "$script_dir/.." && pwd)"
export XVERIF_HOME="${XVERIF_HOME:-$root}"

python_bin="${PYTHON:-${XVERIF_XCOV_PYTHON:-python3}}"
command -v "$python_bin" >/dev/null 2>&1 || {
  echo "ERROR: Python interpreter not found: $python_bin; set PYTHON or XVERIF_XCOV_PYTHON" >&2
  exit 2
}

export PYTHONPATH="$root/xcov${PYTHONPATH:+:${PYTHONPATH}}"
exec "$python_bin" -m xcov.cli "$@"
