#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
root="$(cd "$script_dir/.." && pwd)"

python_bin="${PYTHON:-python3}"
command -v "$python_bin" >/dev/null 2>&1 || {
  echo "ERROR: Python interpreter not found: $python_bin; set PYTHON" >&2
  exit 2
}

export PYTHONPATH="$root/xbit/src${PYTHONPATH:+:${PYTHONPATH}}"
exec "$python_bin" -m xbit.cli "$@"
