{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xverif-fixture-registry.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "fixtures"],
  "properties": {
    "version": {"const": "xverif-fixture-registry.v1"},
    "fixtures": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "source_dir", "inputs", "builder", "outputs"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9_.-]+$"},
          "source_dir": {"type": "string"},
          "inputs": {"type": "array", "items": {"type": "string"}, "minItems": 1},
          "extra_inputs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
          "builder": {
            "type": "object",
            "additionalProperties": false,
            "required": ["argv"],
            "properties": {
              "argv": {"type": "array", "items": {"type": "string"}, "minItems": 1},
              "cwd": {"type": "string"},
              "env": {"type": "object", "additionalProperties": {"type": "string"}},
              "default_env": {"type": "object", "additionalProperties": {"type": "string"}},
              "timeout_sec": {"type": "integer", "minimum": 1}
            }
          },
          "outputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "path", "kind"],
              "properties": {
                "name": {"type": "string"},
                "path": {"type": "string"},
                "kind": {"enum": ["file", "dir"]},
                "min_bytes": {"type": "integer", "minimum": 0}
              }
            }
          },
          "tool_env": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
        }
      }
    }
  }
}
