          "data": "stream_v1_top.ready_data",
          "is_wr": "stream_v1_top.ready_cmd == 2'b01",
          "low8": "stream_v1_top.ready_data[7:0]"
        },
        "channel_id": "stream_v1_top.ready_chid",
        "channel_id_valid": "every_beat",
        "allow_interleaving": false,
        "description": "vld/rdy stream with gated valid, slice, concat, compare, and channel"
      },
      "issues": [],
      "semantics": {
        "transfer": "vld/rdy",
        "stall": "enabled"
      }
    },
    "error": null
  },
  "stderr": ""
