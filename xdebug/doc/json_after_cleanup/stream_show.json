{
  "request": {
    "api_version": "xdebug.v1",
    "action": "stream.show",
    "output": {
      "verbosity": "compact"
    },
    "target": {
      "session_id": "fix_stream"
    },
    "args": {
      "stream": "ready_stream"
    }
  },
  "response": {
    "api_version": "xdebug.v1",
    "ok": true,
    "action": "stream.show",
    "tool": {
      "name": "xdebug",
      "version": "0.1.0"
    },
    "session": null,
    "summary": {
      "stream": "ready_stream",
      "handshake": "vld/rdy",
      "packet_enabled": false
    },
    "data": {
      "config": {
        "name": "ready_stream",
        "clock": "stream_v1_top.clk",
        "clock_edge": "posedge",
        "reset": "!stream_v1_top.rst_n",
        "vld": "stream_v1_top.ready_vld && !stream_v1_top.ready_flush",
        "rdy": "stream_v1_top.ready_rdy",
        "data_fields": {
