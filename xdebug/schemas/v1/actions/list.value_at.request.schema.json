{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.list.value_at.request.v1",
  "title": "list.value_at request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "list.value_at"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "clock": {
          "type": "string",
          "description": "采样、统计或协议检查使用的 clock 信号路径。"
        },
        "edge": {
          "type": "string",
          "description": "clock sampling 使用的边沿：posedge、negedge 或 dual。"
        },
        "format": {
          "type": "string",
          "enum": [
            "h",
            "hex",
            "b",
            "bin",
            "binary",
            "d",
            "dec",
            "decimal",
            "array_indexed",
            "json",
            "tsv",
            "csv",
            "u64bin"
          ]
        },
        "name": {
          "type": "string",
          "description": "已保存配置、游标、列表或接口配置名称。"
        },
        "sample_point": {
          "type": "string",
          "enum": [
            "before",
            "after"
          ],
          "description": "posedge/dual 时的采样点：before 或 after；posedge 默认推荐 before。"
        },
        "time": {
          "type": "string",
          "description": "查询或验证的目标时间点。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "name",
        "time",
        "clock"
      ]
    },
    "limits": {
      "type": "object"
    },
    "output": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "list.value_at: 读取 list 内所有信号在指定时间的值。",
  "x-purpose": "读取 list 内所有信号在指定时间的值。",
  "x-how_it_works": "加载 list 后按 clock/time 对所有信号做同一时刻批量读取。",
  "x-when_to_use": "快速比较一组相关信号。",
  "x-arg_contract_notes": "required: name, time, clock"
}
