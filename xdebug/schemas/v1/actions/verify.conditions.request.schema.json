{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.verify.conditions.request.v1",
  "title": "verify.conditions request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "verify.conditions"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "clock": {
          "type": "string",
          "description": "采样、统计或协议检查使用的 clock 信号路径。"
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "expr"
            ],
            "properties": {
              "expr": {
                "type": "string",
                "description": "Expression using aliases from args.signals."
              },
              "name": {
                "type": "string"
              },
              "mode": {
                "type": "string",
                "enum": [
                  "always",
                  "eventually",
                  "never"
                ]
              }
            },
            "additionalProperties": false
          },
          "description": "需要验证的条件列表。"
        },
        "edge": {
          "type": "string",
          "description": "clock sampling 使用的边沿：posedge、negedge 或 dual。"
        },
        "sample_point": {
          "type": "string",
          "enum": [
            "before",
            "after"
          ],
          "description": "posedge/dual 时的采样点：before 或 after；posedge 默认推荐 before。"
        },
        "signals": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          ],
          "description": "信号列表，或 alias 到信号路径的映射。"
        },
        "time": {
          "type": "string",
          "description": "查询或验证的目标时间点。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        },
        "value_format": {
          "type": "string",
          "enum": [
            "hex",
            "bin",
            "dec"
          ],
          "description": "仅控制响应中信号值的显示格式；不影响采样、时间或导出文件格式。"
        }
      },
      "additionalProperties": false,
      "required": [
        "conditions",
        "time",
        "clock",
        "signals"
      ]
    },
    "limits": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Verify multiple conditions at one sampled time.",
  "x-purpose": "在单个时间验证条件集合。",
  "x-how_it_works": "解析 clock/time，按 args.signals 采样 alias，并对 conditions[].expr 求值。",
  "x-when_to_use": "检查某个时间点的多条件事实。",
  "x-arg_contract_notes": "required: conditions, time, clock, signals",
  "x-description-zh": "在单个时间验证条件集合。"
}
