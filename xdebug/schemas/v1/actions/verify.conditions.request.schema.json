{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.verify.conditions.request.v1",
  "title": "verify.conditions request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "verify.conditions"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "at": {
          "type": "string"
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "object"
          },
          "description": "需要验证的条件列表。"
        },
        "time": {
          "type": "string",
          "description": "查询或验证的目标时间点。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "conditions",
        "time"
      ]
    },
    "limits": {
      "type": "object"
    },
    "output": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "verify.conditions: 在单个时间验证条件集合。",
  "x-purpose": "在单个时间验证条件集合。",
  "x-how_it_works": "解析 time，读取条件引用信号并求值。",
  "x-when_to_use": "检查某个时间点的多条件事实。",
  "x-arg_contract_notes": "required: conditions, time"
}
