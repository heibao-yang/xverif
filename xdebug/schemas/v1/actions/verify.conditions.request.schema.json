{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.verify.conditions.request.v1",
  "title": "verify.conditions request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "verify.conditions"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "clock": {
          "type": "string",
          "description": "采样、统计或协议检查使用的 clock 信号路径。"
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "object"
          },
          "description": "需要验证的条件列表。"
        },
        "edge": {
          "type": "string",
          "description": "clock sampling 使用的边沿：posedge、negedge 或 dual。"
        },
        "sample_point": {
          "type": "string",
          "enum": [
            "before",
            "after"
          ],
          "description": "posedge/dual 时的采样点：before 或 after；posedge 默认推荐 before。"
        },
        "time": {
          "type": "string",
          "description": "查询或验证的目标时间点。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "conditions",
        "time",
        "clock"
      ]
    },
    "limits": {
      "type": "object"
    },
    "output": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "verify.conditions: 在单个时间验证条件集合。",
  "x-purpose": "在单个时间验证条件集合。",
  "x-how_it_works": "解析 clock/time，读取条件引用信号并求值。",
  "x-when_to_use": "检查某个时间点的多条件事实。",
  "x-arg_contract_notes": "required: conditions, time, clock"
}
