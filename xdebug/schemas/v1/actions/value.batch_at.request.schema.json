{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.value.batch_at.request.v1",
  "title": "value.batch_at request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "value.batch_at"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "clock": {
          "type": "string",
          "description": "采样、统计或协议检查使用的 clock 信号路径。"
        },
        "edge": {
          "type": "string",
          "description": "clock sampling 使用的边沿：posedge、negedge 或 dual。"
        },
        "format": {
          "type": "string",
          "enum": [
            "h",
            "hex",
            "b",
            "bin",
            "binary",
            "d",
            "dec",
            "decimal",
            "array_indexed",
            "json",
            "tsv",
            "csv",
            "u64bin"
          ]
        },
        "sample_point": {
          "type": "string",
          "enum": [
            "before",
            "after"
          ],
          "description": "posedge/dual 时的采样点：before 或 after；posedge 默认推荐 before。"
        },
        "signals": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "信号列表，或 alias 到信号路径的映射。"
        },
        "slice_hint": {
          "type": "object"
        },
        "time": {
          "type": "string",
          "description": "查询或验证的目标时间点。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        },
        "value_format": {
          "type": "string",
          "enum": [
            "hex",
            "bin",
            "dec"
          ],
          "description": "仅控制响应中信号值的显示格式；不影响采样、时间或导出文件格式。"
        }
      },
      "additionalProperties": false,
      "required": [
        "signals",
        "time",
        "clock"
      ]
    },
    "limits": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Read multiple signal values at one sampled waveform time.",
  "x-purpose": "批量读取多个信号值。",
  "x-how_it_works": "对 signals 列表按同一 clock/time 执行 FSDB 读取。",
  "x-when_to_use": "减少多信号同一时刻检查的开销。",
  "x-arg_contract_notes": "required: signals, time, clock",
  "x-description-zh": "批量读取多个信号值。"
}
