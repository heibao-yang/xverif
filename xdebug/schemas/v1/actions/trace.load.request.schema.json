{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.trace.load.request.v1",
  "title": "trace.load request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "trace.load"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "include_statement_only": {
          "type": "boolean"
        },
        "include_trace": {
          "type": "boolean",
          "description": "Allow internal trace evidence collection; public output remains source_context plus signal_path."
        },
        "limit": {
          "type": "integer"
        },
        "no_statement_only": {
          "type": "boolean"
        },
        "role": {
          "type": "string"
        },
        "signal": {
          "type": "string",
          "description": "目标信号路径。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "signal"
      ]
    },
    "limits": {
      "type": "object"
    },
    "output": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "trace.load: 查找信号 load。",
  "x-purpose": "查找信号 load。",
  "x-how_it_works": "从设计数据库遍历信号使用点。",
  "x-when_to_use": "回答信号影响到哪里。",
  "x-arg_contract_notes": "required: signal"
}
