{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.session.close.request.v1",
  "title": "session.close request",
  "type": "object",
  "required": [
    "api_version",
    "action"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "session.close"
      ]
    },
    "target": {
      "type": "object",
      "properties": {
        "session_id": {
          "type": "string",
          "description": "目标 xdebug session 标识。"
        }
      },
      "additionalProperties": true
    },
    "args": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "目标 xdebug session 标识；session_id 的兼容别名。"
        },
        "name": {
          "type": "string",
          "description": "已保存配置、游标、列表或接口配置名称。"
        },
        "session_id": {
          "type": "string",
          "description": "目标 xdebug session 标识。"
        }
      },
      "additionalProperties": false,
      "required": [
        "session_id"
      ]
    },
    "limits": {
      "type": "object"
    },
    "output": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    }
  },
  "anyOf": [
    {
      "required": [
        "target"
      ],
      "properties": {
        "target": {
          "required": [
            "session_id"
          ]
        }
      }
    },
    {
      "required": [
        "args"
      ],
      "properties": {
        "args": {
          "required": [
            "session_id"
          ]
        }
      }
    },
    {
      "required": [
        "args"
      ],
      "properties": {
        "args": {
          "required": [
            "id"
          ]
        }
      }
    }
  ],
  "additionalProperties": false,
  "description": "session.close: 关闭指定 session。",
  "x-purpose": "关闭指定 session。",
  "x-how_it_works": "释放该 session 的 runtime 资源并从管理器移除。",
  "x-when_to_use": "结束不再使用的调试上下文。",
  "x-arg_contract_notes": "required: target.session_id or args.session_id or args.id"
}
