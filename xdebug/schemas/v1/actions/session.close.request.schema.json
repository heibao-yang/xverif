{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.session.close.request.v1",
  "title": "session.close request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "target"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "session.close"
      ]
    },
    "target": {
      "type": "object",
      "required": [
        "session_id"
      ],
      "properties": {
        "session_id": {
          "type": "string",
          "description": "目标 xdebug session 标识。"
        }
      },
      "additionalProperties": false
    },
    "args": {
      "type": "object",
      "properties": {
        "session_id": {
          "type": "string",
          "description": "Action-specific session_id input. Its type and accepted values are defined by this schema."
        }
      },
      "additionalProperties": false,
      "required": []
    },
    "limits": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Close a debug session and release its runtime resources.",
  "x-purpose": "关闭指定 session。",
  "x-how_it_works": "释放该 session 的 runtime 资源并从管理器移除。",
  "x-when_to_use": "结束不再使用的调试上下文。",
  "x-arg_contract_notes": "required: target.session_id",
  "x-description-zh": "关闭指定 session。",
  "x-agent": {
    "use_when": [
      "关闭指定 session。"
    ],
    "do_not_use_when": [
      "不要把本 action 用于 session.doctor、session.gc 的业务目标；请改用列出的同域 action。"
    ],
    "alternatives": [
      {
        "action": "session.doctor",
        "when": "诊断当前 session。"
      },
      {
        "action": "session.gc",
        "when": "清理过期 session。"
      }
    ],
    "constraints": [
      "required: target.session_id"
    ]
  }
}
