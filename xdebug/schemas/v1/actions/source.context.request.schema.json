{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.source.context.request.v1",
  "title": "source.context request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "source.context"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "context_lines": {
          "type": "integer"
        },
        "file": {
          "type": "string",
          "description": "源码文件路径。"
        },
        "line": {
          "type": "integer",
          "description": "源码行号。"
        },
        "symbol": {
          "type": "string"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "file",
        "line"
      ]
    },
    "limits": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "source.context: 读取源码上下文。",
  "x-purpose": "读取源码上下文。",
  "x-how_it_works": "按 file/line 读取附近源码并尝试识别 enclosing 结构。",
  "x-when_to_use": "把查询结果锚定到可读源码位置。",
  "x-arg_contract_notes": "required: file, line"
}
