{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.stream.query.request.v1",
  "title": "stream.query request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "action": {
      "type": "string",
      "enum": [
        "stream.query"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "required": [
        "stream",
        "query"
      ],
      "properties": {
        "channel": {
          "type": "string"
        },
        "field_scope": {
          "type": "string",
          "enum": [
            "beat",
            "stable",
            "any"
          ]
        },
        "line_limit": {
          "type": "integer",
          "minimum": 1,
          "description": "控制 response/xout 中 item、finding、event、transaction 或 row 的最大返回行数。"
        },
        "match": {
          "type": "object",
          "properties": {
            "field": {
              "type": "string"
            },
            "op": {
              "type": "string",
              "enum": [
                "==",
                "!=",
                "<",
                "<=",
                ">",
                ">=",
                "range"
              ]
            },
            "value": {
              "type": "string"
            },
            "lo": {
              "type": "string"
            },
            "hi": {
              "type": "string"
            },
            "mask": {
              "type": "string"
            },
            "field_scope": {
              "type": "string",
              "enum": [
                "beat",
                "stable",
                "any"
              ]
            }
          },
          "required": [
            "field"
          ],
          "additionalProperties": false
        },
        "packet_index": {
          "type": "integer",
          "minimum": 0
        },
        "query": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "object"
            }
          ],
          "description": "stream 查询条件。"
        },
        "stream": {
          "type": "string",
          "description": "已保存 stream 配置名称。"
        },
        "time_range": {
          "type": "object",
          "properties": {
            "begin": {
              "type": "string"
            },
            "end": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "description": "查询或分析的时间窗口。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false
    },
    "limits": {
      "type": "object"
    },
    "output": {
      "type": "object"
    },
    "request_id": {
      "type": "string"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "stream.query: 查询 stream transfer。",
  "x-purpose": "查询 stream transfer。",
  "x-how_it_works": "按 stream 配置和 query 条件扫描握手/beat。",
  "x-when_to_use": "抽取流事务或 beats。",
  "x-arg_contract_notes": "required: stream, query"
}
