{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.stream.query.request.v1",
  "title": "stream.query request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "target",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "action": {
      "type": "string",
      "enum": [
        "stream.query"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "required": [
        "stream",
        "query"
      ],
      "properties": {
        "stream": {
          "type": "string"
        },
        "query": {
          "type": "string",
          "enum": [
            "summary",
            "first_transfer",
            "last_transfer",
            "transfer_window",
            "first_stall",
            "last_stall",
            "stall_window",
            "first_packet",
            "last_packet",
            "packet_at",
            "packet_window",
            "match_field"
          ]
        },
        "start": {
          "type": "string"
        },
        "end": {
          "type": "string"
        },
        "time_range": {
          "type": "object"
        },
        "limit": {
          "type": "integer"
        },
        "channel": {
          "type": "string"
        },
        "match": {
          "type": "object"
        },
        "packet_index": {
          "type": "integer",
          "minimum": 0
        },
        "field_scope": {
          "type": "string",
          "enum": [
            "beat",
            "stable",
            "any"
          ]
        },
        "clock": {
          "type": "string"
        },
        "clk": {
          "type": "string"
        },
        "payload": {
          "type": "string"
        },
        "payloads": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "signal": {
          "type": "string"
        },
        "signals": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          ]
        },
        "index": {
          "oneOf": [
            {
              "type": "integer"
            },
            {
              "type": "string"
            }
          ]
        },
        "begin": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "output_file": {
          "type": "string"
        },
        "output_prefix": {
          "type": "string"
        },
        "sampling": {
          "type": "string"
        },
        "max_samples": {
          "type": "integer"
        },
        "max_events": {
          "type": "integer"
        },
        "max_findings": {
          "type": "integer"
        },
        "rst_n": {
          "type": "string"
        },
        "edge": {
          "type": "string"
        },
        "format": {
          "type": "string"
        },
        "streams": {
          "type": "array"
        },
        "config_path": {
          "type": "string"
        },
        "rc_path": {
          "type": "string"
        },
        "requested_time": {
          "type": "string"
        },
        "from_signal": {
          "type": "string"
        },
        "to_signal": {
          "type": "string"
        },
        "file": {
          "type": "string"
        },
        "line": {
          "type": "integer"
        },
        "expr": {
          "type": "string"
        },
        "scope": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "op": {
          "type": "string"
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "time": {
          "type": "string"
        },
        "vld": {
          "type": "string"
        },
        "cnt": {
          "type": "string"
        },
        "requests": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "session_id": {
          "type": "string"
        },
        "valid": {
          "type": "string"
        },
        "ready": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "limits": {
      "type": "object"
    },
    "output": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
