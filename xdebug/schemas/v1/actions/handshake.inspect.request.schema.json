{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.handshake.inspect.request.v1",
  "title": "handshake.inspect request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "handshake.inspect"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "clock": {
          "type": "string",
          "description": "采样、统计或协议检查使用的 clock 信号路径。"
        },
        "data": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "edge": {
          "type": "string",
          "description": "clock sampling 使用的边沿：posedge、negedge 或 dual。"
        },
        "line_limit": {
          "type": "integer",
          "minimum": 1,
          "description": "控制 response/xout 中 item、finding、event、transaction 或 row 的最大返回行数。"
        },
        "ready": {
          "type": "string",
          "description": "valid-ready 握手中的 ready 信号路径。"
        },
        "rules": {
          "oneOf": [
            {
              "type": "array"
            },
            {
              "type": "object"
            }
          ]
        },
        "sample_point": {
          "type": "string",
          "enum": [
            "before",
            "after"
          ],
          "description": "posedge/dual 时的采样点：before 或 after；posedge 默认推荐 before。"
        },
        "time_range": {
          "type": "object",
          "properties": {
            "begin": {
              "type": "string"
            },
            "end": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "description": "查询或分析的时间窗口。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        },
        "valid": {
          "type": "string",
          "description": "valid-ready 握手或采样检查中的 valid 信号路径。"
        }
      },
      "additionalProperties": false,
      "required": [
        "clock",
        "valid",
        "ready"
      ]
    },
    "limits": {
      "type": "object"
    },
    "output": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "handshake.inspect: 检查 valid/ready 握手。",
  "x-purpose": "检查 valid/ready 握手。",
  "x-how_it_works": "按 clock 采样 valid/ready/data，统计 stall、transfer 和数据稳定性违规。",
  "x-when_to_use": "定位握手停顿和协议风险。",
  "x-arg_contract_notes": "required: clock, valid, ready"
}
