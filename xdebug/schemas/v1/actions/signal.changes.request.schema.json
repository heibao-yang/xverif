{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.signal.changes.request.v1",
  "title": "signal.changes request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "signal.changes"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "aggregate_only": {
          "type": "boolean",
          "description": "Return only counts, first/last/final values, and warnings; omit data.changes rows."
        },
        "line_limit": {
          "type": "integer",
          "minimum": 1,
          "description": "控制 response/xout 中 item、finding、event、transaction 或 row 的最大返回行数。"
        },
        "mode": {
          "type": "string"
        },
        "signal": {
          "type": "string",
          "description": "目标信号路径。"
        },
        "time_range": {
          "type": "object",
          "properties": {
            "begin": {
              "type": "string"
            },
            "end": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "description": "查询或分析的时间窗口。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "signal"
      ]
    },
    "limits": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "signal.changes: 读取信号变化点。",
  "x-purpose": "读取信号变化点。",
  "x-how_it_works": "扫描 FSDB value changes，支持窗口、line_limit 和聚合。",
  "x-when_to_use": "看信号何时跳变。",
  "x-arg_contract_notes": "required: signal"
}
