{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.stream.export.response.v1",
  "title": "stream.export response",
  "type": "object",
  "required": [
    "api_version",
    "ok",
    "action",
    "summary",
    "data"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "ok": {
      "type": "boolean"
    },
    "action": {
      "type": "string",
      "enum": [
        "stream.export"
      ]
    },
    "summary": {
      "type": "object",
      "additionalProperties": true
    },
    "data": {
      "type": "object",
      "properties": {
        "output": {
          "type": "object",
          "properties": {
            "path": {"type": "string"},
            "meta_path": {"type": "string"},
            "file_format": {"type": "string", "enum": ["tsv", "csv", "xout"]}
          },
          "required": ["path", "meta_path", "file_format"],
          "additionalProperties": true
        },
        "kind": {"type": "string", "enum": ["transfer", "packet", "packet_beats"]},
        "row_count": {"type": "integer"}
      },
      "required": ["kind", "row_count"],
      "additionalProperties": true
    },
    "error": {},
    "warnings": {
      "type": "array"
    },
    "meta": {
      "type": "object"
    }
  },
  "additionalProperties": true,
  "description": "stream.export response: 导出 stream 查询结果。",
  "x-output_notes": "返回该 action 的 summary/data/error/meta；具体字段以 response schema 和 response example 为准。"
}
