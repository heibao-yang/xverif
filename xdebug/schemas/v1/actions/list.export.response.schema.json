{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.list.export.response.v1",
  "title": "list.export response",
  "type": "object",
  "required": [
    "api_version",
    "ok",
    "action",
    "summary",
    "data"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "ok": {
      "type": "boolean"
    },
    "action": {
      "type": "string",
      "enum": [
        "list.export"
      ]
    },
    "summary": {
      "type": "object",
      "properties": {
        "name": {"type": "string"},
        "signal_count": {"type": "integer"},
        "row_count": {"type": "integer"},
        "format": {"type": "string", "enum": ["u64bin.v1"]},
        "output": {
          "type": "object",
          "properties": {
            "path": {"type": "string"},
            "manifest_path": {"type": "string"}
          },
          "additionalProperties": true
        }
      },
      "required": ["name", "signal_count", "row_count", "format"],
      "additionalProperties": true
    },
    "data": {
      "type": "object",
      "properties": {
        "output": {
          "type": "object",
          "properties": {
            "path": {"type": "string"},
            "manifest_path": {"type": "string"}
          },
          "required": ["path", "manifest_path"],
          "additionalProperties": true
        },
        "signals": {"type": "array"},
        "begin": {"type": "string"},
        "end": {"type": "string"}
      },
      "required": ["output", "signals", "begin", "end"],
      "additionalProperties": true
    },
    "warnings": {
      "type": "array"
    },
    "error": {},
    "meta": {
      "type": "object"
    }
  },
  "additionalProperties": true,
  "description": "list.export response: 导出 list 数据。",
  "x-output_notes": "返回该 action 的 summary/data/error/meta；具体字段以 response schema 和 response example 为准。"
}
