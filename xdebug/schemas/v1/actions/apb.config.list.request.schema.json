{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.apb.config.list.request.v1",
  "title": "apb.config.list request",
  "type": "object",
  "required": [
    "api_version",
    "action"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "apb.config.list"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Saved-object name in this action namespace; do not assume names are shared by cursors, lists, and protocol configs."
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ],
          "description": "Interprets only unitless time numbers; it never overrides a time string that already has a unit."
        }
      },
      "additionalProperties": false,
      "required": []
    },
    "limits": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "List saved APB interface configurations.",
  "x-purpose": "列出 APB 配置。",
  "x-how_it_works": "读取 APB 配置存储；args:{} 列全部，args.name 显示单个配置详情。",
  "x-when_to_use": "查看可用 APB interface 名称。",
  "x-arg_contract_notes": "args:{} list all; optional name shows one config",
  "x-description-zh": "列出 APB 配置。",
  "x-agent": {
    "use_when": [
      "列出 APB 配置。"
    ],
    "do_not_use_when": [
      "不要把本 action 用于 apb.config.load、apb.cursor 的业务目标；请改用列出的同域 action。"
    ],
    "alternatives": [
      {
        "action": "apb.config.load",
        "when": "加载 APB 配置。"
      },
      {
        "action": "apb.cursor",
        "when": "在 APB transfer 间移动游标。"
      }
    ],
    "constraints": [
      "args:{} list all; optional name shows one config"
    ]
  }
}
