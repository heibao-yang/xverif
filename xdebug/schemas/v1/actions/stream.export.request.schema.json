{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.stream.export.request.v1",
  "title": "stream.export request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "action": {
      "type": "string",
      "enum": [
        "stream.export"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "required": [
        "stream"
      ],
      "properties": {
        "begin": {
          "type": "string",
          "description": "查询窗口起始时间。"
        },
        "channel": {
          "type": "string"
        },
        "end": {
          "type": "string",
          "description": "查询窗口结束时间。"
        },
        "format": {
          "type": "string",
          "enum": [
            "h",
            "hex",
            "b",
            "bin",
            "binary",
            "d",
            "dec",
            "decimal",
            "array_indexed",
            "json",
            "tsv",
            "csv",
            "u64bin"
          ]
        },
        "kind": {
          "type": "string",
          "description": "导出或查询的结果类型。"
        },
        "limit": {
          "type": "integer"
        },
        "name": {
          "type": "string",
          "description": "已保存配置、游标、列表或接口配置名称。"
        },
        "output_file": {
          "type": "string",
          "description": "导出结果写入的文件路径。"
        },
        "start": {
          "type": "string",
          "description": "查询窗口起始时间。"
        },
        "stream": {
          "type": "string",
          "description": "已保存 stream 配置名称。"
        },
        "time_range": {
          "type": "object",
          "description": "查询或分析的时间窗口。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "packet_beats"
              }
            }
          },
          "then": {
            "required": [
              "output_file"
            ]
          }
        }
      ]
    },
    "limits": {
      "type": "object"
    },
    "output": {
      "type": "object"
    },
    "request_id": {
      "type": "string"
    },
    "auth_token": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "stream.export: 导出 stream 查询结果。",
  "x-purpose": "导出 stream 查询结果。",
  "x-how_it_works": "运行 stream query 后按 kind/format 写出。packet_beats 需要 output_file。",
  "x-when_to_use": "把流数据输出给外部脚本。",
  "x-arg_contract_notes": "required: stream; when kind=packet_beats: output_file"
}
