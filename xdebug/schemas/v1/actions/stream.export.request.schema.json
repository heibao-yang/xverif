{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.stream.export.request.v1",
  "title": "stream.export request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "action": {
      "type": "string",
      "enum": [
        "stream.export"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "required": [
        "stream"
      ],
      "properties": {
        "channel": {
          "type": "string"
        },
        "format": {
          "type": "string",
          "enum": [
            "tsv",
            "csv",
            "xout"
          ],
          "description": "stream.export file format."
        },
        "kind": {
          "type": "string",
          "enum": [
            "transfer",
            "packet",
            "packet_beats"
          ],
          "description": "导出或查询的结果类型。"
        },
        "line_limit": {
          "type": "integer",
          "minimum": 1,
          "description": "控制 response/xout 中 item、finding、event、transaction 或 row 的最大返回行数。"
        },
        "output": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string"
            },
            "file_format": {
              "type": "string"
            },
            "verbose": {
              "type": "boolean"
            }
          },
          "additionalProperties": false,
          "description": "导出配置对象；路径统一使用 output.path。"
        },
        "stream": {
          "type": "string",
          "description": "已保存 stream 配置名称。"
        },
        "time_range": {
          "type": "object",
          "description": "查询或分析的时间窗口。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "packet_beats"
              }
            }
          },
          "then": {
            "required": [
              "output"
            ]
          }
        }
      ]
    },
    "limits": {
      "type": "object"
    },
    "output": {
      "type": "object"
    },
    "request_id": {
      "type": "string"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "stream.export: 导出 stream 查询结果。",
  "x-purpose": "导出 stream 查询结果。",
  "x-how_it_works": "运行 stream query 后按 kind/format 写出；kind 只能是 transfer、packet、packet_beats。",
  "x-when_to_use": "把流数据输出给外部脚本。",
  "x-arg_contract_notes": "required: stream; kind: transfer / packet / packet_beats; format: tsv / csv / xout; when kind=packet_beats: output"
}
