{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.trace.driver.request.v1",
  "title": "trace.driver request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "trace.driver"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "include_statement_only": {
          "type": "boolean"
        },
        "include_trace": {
          "type": "boolean",
          "description": "Allow internal trace evidence collection; public output remains source_context plus signal_path."
        },
        "limit": {
          "type": "integer"
        },
        "no_statement_only": {
          "type": "boolean"
        },
        "role": {
          "type": "string"
        },
        "signal": {
          "type": "string",
          "description": "目标信号路径。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "signal"
      ]
    },
    "limits": {
      "type": "object"
    },
    "output": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "trace.driver: 查找信号直接 driver。",
  "x-purpose": "查找信号直接 driver。",
  "x-how_it_works": "调用设计 trace 能力分析赋值、依赖和来源。",
  "x-when_to_use": "解释某个信号由什么驱动。",
  "x-arg_contract_notes": "required: signal"
}
