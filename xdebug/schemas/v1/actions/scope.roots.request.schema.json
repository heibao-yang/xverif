{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.scope.roots.request.v1",
  "title": "scope.roots request",
  "type": "object",
  "required": [
    "api_version",
    "action"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "scope.roots"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "source": {
          "type": "string",
          "enum": [
            "auto",
            "wave",
            "design"
          ],
          "default": "auto",
          "description": "Action-specific source input. Its type and accepted values are defined by this schema."
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ],
          "description": "Interprets only unitless time numbers; it never overrides a time string that already has a unit."
        }
      },
      "additionalProperties": false,
      "required": []
    },
    "limits": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Discover waveform and design hierarchy roots.",
  "x-purpose": "发现 waveform/design 根。",
  "x-how_it_works": "合并 FSDB 根和可用设计根信息。",
  "x-when_to_use": "判断 session 绑定的顶层和路径规范。",
  "x-arg_contract_notes": "none",
  "x-description-zh": "发现 waveform/design 根。",
  "x-agent": {
    "use_when": [
      "发现 waveform/design 根。"
    ],
    "do_not_use_when": [
      "不要把本 action 用于 scope.list 的业务目标；请改用列出的同域 action。"
    ],
    "alternatives": [
      {
        "action": "scope.list",
        "when": "列出 FSDB scope 或信号。"
      }
    ],
    "constraints": [
      "none"
    ]
  }
}
