{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.axi.export.request.v1",
  "title": "axi.export request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "axi.export"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "已保存配置、游标、列表或接口配置名称。"
        },
        "output": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string"
            },
            "file_format": {
              "type": "string",
              "enum": [
                "tsv",
                "csv"
              ],
              "description": "axi.export file format."
            },
            "verbose": {
              "type": "boolean"
            }
          },
          "additionalProperties": false,
          "description": "导出配置对象；路径统一使用 output.path。"
        },
        "time_range": {
          "type": "object",
          "properties": {
            "begin": {
              "type": "string"
            },
            "end": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "description": "查询或分析的时间窗口。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false,
      "anyOf": [
        {
          "required": [
            "time_range"
          ]
        }
      ]
    },
    "limits": {
      "type": "object"
    },
    "output": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "axi.export: 导出 AXI 数据。",
  "x-purpose": "导出 AXI 数据。",
  "x-how_it_works": "按 name 和 time_range 查询 AXI，再按 format/output.path 写出。",
  "x-when_to_use": "给外部表格或脚本分析。",
  "x-arg_contract_notes": "required: name; also one of: time_range"
}
