{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.axi.export.request.v1",
  "title": "axi.export request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "axi.export"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "begin": {
          "type": "string",
          "description": "查询窗口起始时间。"
        },
        "end": {
          "type": "string",
          "description": "查询窗口结束时间。"
        },
        "format": {
          "type": "string",
          "enum": [
            "h",
            "hex",
            "b",
            "bin",
            "binary",
            "d",
            "dec",
            "decimal",
            "array_indexed",
            "json",
            "tsv",
            "csv",
            "u64bin"
          ]
        },
        "name": {
          "type": "string",
          "description": "已保存配置、游标、列表或接口配置名称。"
        },
        "output_prefix": {
          "type": "string"
        },
        "start": {
          "type": "string",
          "description": "查询窗口起始时间。"
        },
        "time_range": {
          "type": "object",
          "description": "查询或分析的时间窗口。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        },
        "to": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "anyOf": [
        {
          "required": [
            "time_range"
          ]
        },
        {
          "required": [
            "start",
            "end"
          ]
        }
      ]
    },
    "limits": {
      "type": "object"
    },
    "output": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "axi.export: 导出 AXI 数据。",
  "x-purpose": "导出 AXI 数据。",
  "x-how_it_works": "按 name 和时间范围查询 AXI，再按 format/output_prefix 写出。",
  "x-when_to_use": "给外部表格或脚本分析。",
  "x-arg_contract_notes": "required: name; also one of: time_range / start + end"
}
