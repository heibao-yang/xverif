{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.axi.export.request.v1",
  "title": "axi.export request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "target",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "axi.export"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "已保存配置、游标、列表或接口配置名称。"
        },
        "time_range": {
          "type": "object",
          "description": "查询或分析的时间窗口。"
        },
        "start": {
          "type": "string",
          "description": "查询窗口起始时间。"
        },
        "end": {
          "type": "string",
          "description": "查询窗口结束时间。"
        },
        "begin": {
          "type": "string"
        },
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "format": {
          "type": "string",
          "enum": [
            "tsv",
            "csv"
          ]
        },
        "output_prefix": {
          "type": "string"
        },
        "clock": {
          "type": "string"
        },
        "clk": {
          "type": "string"
        },
        "payload": {
          "type": "string"
        },
        "payloads": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "signal": {
          "type": "string"
        },
        "signals": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          ]
        },
        "index": {
          "oneOf": [
            {
              "type": "integer"
            },
            {
              "type": "string"
            }
          ]
        },
        "kind": {
          "type": "string"
        },
        "output_file": {
          "type": "string"
        },
        "sampling": {
          "type": "string"
        },
        "max_samples": {
          "type": "integer"
        },
        "max_events": {
          "type": "integer"
        },
        "max_findings": {
          "type": "integer"
        },
        "limit": {
          "type": "integer"
        },
        "rst_n": {
          "type": "string"
        },
        "edge": {
          "type": "string"
        },
        "stream": {
          "type": "string"
        },
        "query": {
          "type": "object"
        },
        "streams": {
          "type": "array"
        },
        "config_path": {
          "type": "string"
        },
        "rc_path": {
          "type": "string"
        },
        "requested_time": {
          "type": "string"
        },
        "from_signal": {
          "type": "string"
        },
        "to_signal": {
          "type": "string"
        },
        "file": {
          "type": "string"
        },
        "line": {
          "type": "integer"
        },
        "expr": {
          "type": "string"
        },
        "scope": {
          "type": "string"
        },
        "op": {
          "type": "string"
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "time": {
          "type": "string"
        },
        "vld": {
          "type": "string"
        },
        "cnt": {
          "type": "string"
        },
        "requests": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "session_id": {
          "type": "string"
        },
        "valid": {
          "type": "string"
        },
        "ready": {
          "type": "string"
        }
      },
      "additionalProperties": true,
      "anyOf": [
        {
          "required": [
            "time_range"
          ]
        },
        {
          "required": [
            "start",
            "end"
          ]
        }
      ]
    },
    "limits": {
      "type": "object"
    },
    "output": {
      "type": "object"
    }
  },
  "additionalProperties": true,
  "description": "axi.export: 导出 AXI 数据。",
  "x-purpose": "导出 AXI 数据。",
  "x-how_it_works": "按 name 和时间范围查询 AXI，再按 format/output_prefix 写出。",
  "x-when_to_use": "给外部表格或脚本分析。",
  "x-arg_contract_notes": "required: name; also one of: time_range / start + end"
}
