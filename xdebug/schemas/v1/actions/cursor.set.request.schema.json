{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.cursor.set.request.v1",
  "title": "cursor.set request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "cursor.set"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "已保存配置、游标、列表或接口配置名称。"
        },
        "time": {
          "type": "string",
          "description": "查询或验证的目标时间点。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "name",
        "time"
      ]
    },
    "limits": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "cursor.set: 保存命名时间游标。",
  "x-purpose": "保存命名时间游标。",
  "x-how_it_works": "解析 time/at 为 FSDB 时间，写入 CursorManager，可设 active。",
  "x-when_to_use": "给后续窗口、比较和人工定位复用时间点。",
  "x-arg_contract_notes": "required: name, time"
}
