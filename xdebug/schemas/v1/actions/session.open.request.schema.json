{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.session.open.request.v1",
  "title": "session.open request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "session.open"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "bind": {
          "type": "string"
        },
        "bind_host": {
          "type": "string"
        },
        "host": {
          "type": "string"
        },
        "name": {
          "type": "string",
          "description": "已保存配置、游标、列表或接口配置名称。"
        },
        "port": {
          "type": "integer"
        },
        "session_id": {
          "type": "string",
          "description": "目标 xdebug session 标识。"
        },
        "transport": {
          "type": "string",
          "enum": [
            "uds",
            "tcp",
            "file"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "name"
      ]
    },
    "limits": {
      "type": "object"
    },
    "output": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "session.open: 打开 design/waveform session。",
  "x-purpose": "打开 design/waveform session。",
  "x-how_it_works": "解析 target 中的 daidir/fsdb，初始化统一 engine session 和底层资源。",
  "x-when_to_use": "建立后续 design/waveform 查询的资源上下文。",
  "x-arg_contract_notes": "required: name"
}
