                "direction": {
                  "enum": [
                    "write",
                    "read"
                  ]
                },
                "latency": {
                  "type": "string",
                  "description": "规范化时间字符串。"
                },
                "phase_order": {
                  "type": "string"
                },
                "response_dependency_violation": {
                  "type": "boolean"
                },
                "match_time": {
                  "type": "string",
                  "description": "规范化时间字符串。"
                },
                "address": {
                  "type": "object",
                  "properties": {
                    "channel": {
                      "enum": [
                        "aw",
                        "ar"
                      ]
                    },
                    "valid_begin_time": {
                      "type": "string",
                      "description": "规范化时间字符串。"
                    },
                    "handshake_time": {
                      "type": "string",
                      "description": "规范化时间字符串。"
                    },
                    "addr": {
                      "oneOf": [
                        {
                          "type": "integer"
                        },
                        {
                          "type": "string"
                        }
                      ]
                    },
                    "id": {
                      "oneOf": [
                        {
                          "type": "integer"
                        },
                        {
                          "type": "string"
                        }
                      ]
                    },
                    "len": {
                      "oneOf": [
                        {
                          "type": "integer"
                        },
                        {
                          "type": "string"
                        }
                      ]
                    },
                    "size": {
                      "oneOf": [
                        {
                          "type": "integer"
                        },
                        {
                          "type": "string"
                        }
                      ]
                    },
                    "burst": {
                      "oneOf": [
                        {
                          "type": "integer"
                        },
                        {
                          "type": "string"
                        }
                      ]
                    }
                  },
                  "additionalProperties": false,
                  "required": [
                    "channel",
                    "handshake_time",
                    "addr",
                    "id",
                    "len",
                    "size",
                    "burst"
                  ]
                },
                "data": {
                  "type": "object",
                  "properties": {
                    "channel": {
                      "enum": [
                        "w",
                        "r"
                      ]
                    },
                    "valid_begin_time": {
                      "type": "string",
                      "description": "规范化时间字符串。"
                    },
                    "first_handshake_time": {
                      "type": "string",
                      "description": "规范化时间字符串。"
                    },
                    "last_handshake_time": {
                      "type": "string",
                      "description": "规范化时间字符串。"
                    },
                    "beat_count": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "expected_beat_count": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "beats": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "index": {
                            "type": "integer",
                            "minimum": 1
                          },
                          "handshake_time": {
                            "type": "string",
                            "description": "规范化时间字符串。"
                          },
                          "data": {
                            "oneOf": [
                              {
                                "type": "integer"
                              },
                              {
                                "type": "string"
                              }
                            ]
                          },
                          "last": {
                            "type": "boolean"
                          },
                          "wstrb": {
                            "oneOf": [
                              {
                                "type": "integer"
                              },
                              {
                                "type": "string"
                              }
                            ]
                          },
                          "resp": {
                            "oneOf": [
                              {
                                "type": "integer"
                              },
                              {
                                "type": "string"
                              }
                            ]
                          }
                        },
                        "additionalProperties": false,
                        "required": [
                          "index",
                          "handshake_time",
                          "data",
                          "last"
                        ]
                      }
                    }
                  },
                  "additionalProperties": false,
                  "required": [
                    "channel",
                    "first_handshake_time",
                    "last_handshake_time",
                    "beat_count",
                    "expected_beat_count"
                  ]
                },
                "response": {
                  "type": "object",
                  "properties": {
                    "channel": {
                      "enum": [
                        "b",
                        "r"
                      ]
                    },
                    "handshake_time": {
                      "type": "string",
                      "description": "规范化时间字符串。"
                    },
                    "resp": {
                      "oneOf": [
                        {
                          "type": "integer"
                        },
                        {
                          "type": "string"
                        }
                      ]
                    }
                  },
                  "additionalProperties": false,
                  "required": [
                    "channel",
                    "handshake_time",
                    "resp"
                  ]
                }
              },
              "additionalProperties": false,
              "required": [
                "direction",
                "latency",
                "response_dependency_violation",
                "address",
                "response"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "null"
        }
      ]
    },
    "error": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "code": {
              "type": "string"
            },
            "message": {
              "type": "string"
            },
            "recoverable": {
              "type": "boolean"
            },
            "error_layer": {
              "type": "string"
            },
            "invalid_arg": {
              "type": "string"
            },
            "expected": {
              "type": "string"
            },
            "received": {},
            "received_type": {
              "type": "string"
            },
            "allowed_values": {},
            "available_values": {},
            "did_you_mean": {},
            "schema_path": {
              "type": "string"
            },
            "required_any_of": {},
            "missing_name": {
              "type": "string"
            },
            "missing_resource": {
              "type": "string"
            },
            "next_actions": {},
            "example_note": {
              "type": "string"
            },
            "correct_example": {},
            "cause_code": {
              "type": "string"
            },
            "validation": {}
          },
          "additionalProperties": false,
          "required": [
            "code",
            "message",
            "recoverable",
            "error_layer"
          ]
        },
        {
          "type": "null"
        }
      ]
    },
    "meta": {
      "type": "object",
      "properties": {
        "truncated": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
