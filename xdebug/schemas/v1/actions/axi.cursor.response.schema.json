    "session": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "session_id": {
              "type": "string"
            },
            "mode": {
              "type": "string"
            },
            "daidir": {
              "type": "string"
            },
            "dbdir": {
              "type": "string"
            },
            "dbdir_path": {
              "type": "string"
            },
            "design_file": {
              "type": "string"
            },
            "fsdb": {
              "type": "string"
            },
            "fsdb_file": {
              "type": "string"
            },
            "socket_path": {
              "type": "string"
            },
            "transport": {
              "type": "string"
            },
            "file_dir": {
              "type": "string"
            },
            "host": {
              "type": "string"
            },
            "bind_host": {
              "type": "string"
            },
            "server_host": {
              "type": "string"
            },
            "pid": {
              "type": "integer"
            },
            "port": {
              "type": "integer"
            },
            "server_pid": {
              "type": "integer"
            },
            "created_at": {
              "type": "integer"
            },
            "last_active": {
              "type": "integer"
            },
            "dbdir_mtime": {
              "type": "integer"
            },
            "dbdir_size": {
              "type": "integer"
            },
            "dbdir_dev": {
              "type": "integer"
            },
            "dbdir_inode": {
              "type": "integer"
            },
            "fsdb_mtime": {
              "type": "integer"
            },
            "fsdb_size": {
              "type": "integer"
            },
            "fsdb_dev": {
              "type": "integer"
            },
            "fsdb_inode": {
              "type": "integer"
            },
            "healthy": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "null"
        }
      ]
    },
    "schema_version": {
      "type": "string"
    },
    "text": {
      "type": "string"
    },
    "summary": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "op": {
              "type": "string"
            },
            "direction": {
              "enum": [
                "read",
                "write",
                "all"
              ]
            },
            "found": {
              "type": "boolean"
            },
            "index": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0
            },
            "index_base": {
              "type": "integer",
              "minimum": 0
            },
            "total_count": {
              "type": "integer",
              "minimum": 0
            },
            "at_begin": {
              "type": "boolean"
            },
            "at_end": {
              "type": "boolean"
            }
