{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.signal.resolve.request.v1",
  "title": "signal.resolve request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "signal.resolve"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "signal": {
          "type": "string",
          "description": "Final leaf signal path. Aggregate, array, and struct roots are not expanded automatically."
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ],
          "description": "Interprets only unitless time numbers; it never overrides a time string that already has a unit."
        }
      },
      "additionalProperties": false,
      "required": [
        "signal"
      ]
    },
    "limits": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Resolve a design signal to canonical candidates.",
  "x-purpose": "解析设计信号。",
  "x-how_it_works": "在设计数据库里查找 signal 并返回候选/规范路径。",
  "x-when_to_use": "消除层次或别名不确定性。",
  "x-arg_contract_notes": "required: signal",
  "x-description-zh": "解析设计信号。",
  "x-agent": {
    "use_when": [
      "解析设计信号。"
    ],
    "do_not_use_when": [
      "不要把本 action 用于 signal.canonicalize、signal.changes 的业务目标；请改用列出的同域 action。"
    ],
    "alternatives": [
      {
        "action": "signal.canonicalize",
        "when": "返回信号 canonical 名称。"
      },
      {
        "action": "signal.changes",
        "when": "读取信号变化点。"
      }
    ],
    "constraints": [
      "required: signal"
    ]
  }
}
