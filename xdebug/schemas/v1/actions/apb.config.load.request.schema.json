{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.apb.config.load.request.v1",
  "title": "apb.config.load request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "apb.config.load"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "config": {
          "type": "object",
          "description": "内联配置对象。",
          "properties": {
            "clock": {
              "type": "string",
              "minLength": 1
            },
            "rst_n": {
              "type": "string",
              "minLength": 1
            },
            "edge": {
              "type": "string",
              "enum": [
                "posedge",
                "negedge",
                "dual"
              ]
            },
            "sample_point": {
              "type": "string",
              "enum": [
                "before",
                "after"
              ]
            },
            "paddr": {
              "type": "string",
              "minLength": 1
            },
            "psel": {
              "type": "string",
              "minLength": 1
            },
            "penable": {
              "type": "string",
              "minLength": 1
            },
            "pready": {
              "type": "string",
              "minLength": 1
            },
            "pslverr": {
              "type": "string",
              "minLength": 1
            },
            "pwrite": {
              "type": "string",
              "minLength": 1
            },
            "pwdata": {
              "type": "string",
              "minLength": 1
            },
            "prdata": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "clock",
            "rst_n",
            "paddr",
            "psel",
            "penable",
            "pready",
            "pslverr",
            "pwrite",
            "pwdata",
            "prdata"
          ],
          "additionalProperties": false
        },
        "config_path": {
          "type": "string",
          "description": "输入配置文件路径。"
        },
        "name": {
          "type": "string",
          "description": "已保存配置、游标、列表或接口配置名称。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "anyOf": [
        {
          "required": [
            "config"
          ]
        },
        {
          "required": [
            "config_path"
          ]
        }
      ]
    },
    "limits": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Load and validate an APB interface configuration.",
  "x-purpose": "加载 APB 配置。",
  "x-how_it_works": "保存 APB interface 信号映射。",
  "x-when_to_use": "定义后续 APB 查询对象。",
  "x-arg_contract_notes": "required: name; also one of: config / config_path",
  "x-description-zh": "加载 APB 配置。"
}
