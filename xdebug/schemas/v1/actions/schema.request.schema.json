{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.schema.request.v1",
  "title": "schema request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "schema"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "action": {
          "type": "string",
          "description": "Action name whose action-specific schema should be returned."
        },
        "kind": {
          "type": "string",
          "enum": [
            "request",
            "response"
          ],
          "default": "request",
          "description": "Action-specific kind input. Its type and accepted values are defined by this schema."
        }
      },
      "additionalProperties": false,
      "required": [
        "action"
      ]
    },
    "limits": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Return the request or response schema for an action.",
  "x-purpose": "返回指定 action 的 request/response JSON schema。",
  "x-how_it_works": "按 action/kind 查 checked-in schema 文件并原样返回。",
  "x-when_to_use": "让调用方先校验参数和响应结构。",
  "x-arg_contract_notes": "none",
  "x-description-zh": "返回指定 action 的 request/response JSON schema。",
  "x-agent": {
    "use_when": [
      "已知 action 名称，需要其 request 或 response 合同。"
    ],
    "do_not_use_when": [
      "尚未知道 action 名称，或需要实际执行一个 debug 查询。"
    ],
    "alternatives": [
      {
        "action": "actions",
        "when": "需要先发现 action catalog。"
      }
    ],
    "constraints": [
      "none"
    ]
  }
}
