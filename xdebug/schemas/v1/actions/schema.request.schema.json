{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.schema.request.v1",
  "title": "schema request",
  "type": "object",
  "required": [
    "api_version",
    "action"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "schema"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "action": {
          "type": "string",
          "description": "Action name whose action-specific schema should be returned."
        },
        "kind": {
          "type": "string",
          "description": "导出或查询的结果类型。"
        }
      },
      "additionalProperties": false,
      "required": []
    },
    "limits": {
      "type": "object"
    },
    "output": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "schema: 返回指定 action 的 request/response JSON schema。",
  "x-purpose": "返回指定 action 的 request/response JSON schema。",
  "x-how_it_works": "按 action/kind 查 checked-in schema 文件并原样返回。",
  "x-when_to_use": "让调用方先校验参数和响应结构。",
  "x-arg_contract_notes": "none"
}
