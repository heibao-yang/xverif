{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.list.export.request.v1",
  "title": "list.export request",
  "type": "object",
  "required": ["api_version", "action", "target", "args"],
  "properties": {
    "api_version": {"type": "string", "enum": ["xdebug.v1"]},
    "request_id": {"type": "string"},
    "action": {"type": "string", "enum": ["list.export"]},
    "target": {"type": "object"},
    "args": {
      "type": "object",
      "properties": {
        "name": {"type": "string"},
        "list": {"type": "string"},
        "time_range": {"type": "object"},
        "start": {"type": "string"},
        "end": {"type": "string"},
        "begin": {"type": "string"},
        "from": {"type": "string"},
        "to": {"type": "string"},
        "output_dir": {"type": "string"},
        "format": {"type": "string", "enum": ["u64bin", "hex_tsv"]}
      },
      "additionalProperties": true
    },
    "limits": {"type": "object"},
    "output": {"type": "object"}
  },
  "additionalProperties": true
}
