{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.list.export.request.v1",
  "title": "list.export request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "list.export"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "format": {
          "type": "string",
          "enum": [
            "h",
            "hex",
            "b",
            "bin",
            "binary",
            "d",
            "dec",
            "decimal",
            "array_indexed",
            "json",
            "tsv",
            "csv",
            "u64bin"
          ]
        },
        "limit": {
          "type": "integer",
          "description": "返回、扫描或导出的数量上限。"
        },
        "name": {
          "type": "string",
          "description": "已保存配置、游标、列表或接口配置名称。"
        },
        "output": {
          "type": "object",
          "required": [
            "path"
          ],
          "properties": {
            "path": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "description": "导出配置对象；路径统一使用 output.path。"
        },
        "time_range": {
          "type": "object",
          "description": "查询或分析的时间窗口。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "name"
      ]
    },
    "limits": {
      "type": "object"
    },
    "output": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "list.export: 导出 list 数据。",
  "x-purpose": "导出 list 数据。",
  "x-how_it_works": "读取 list 信号并按请求格式写出波形表。",
  "x-when_to_use": "把窗口数据交给外部分析。",
  "x-arg_contract_notes": "required: name"
}
