{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.session.open.response.v1",
  "title": "session.open response",
  "type": "object",
  "required": [
    "api_version",
    "ok",
    "action",
    "summary",
    "data"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "ok": {
      "type": "boolean"
    },
    "action": {
      "type": "string",
      "enum": [
        "session.open"
      ]
    },
    "summary": {
      "type": "object",
      "additionalProperties": true
    },
    "data": {
      "type": "object"
    },
    "findings": {
      "type": "array"
    },
    "warnings": {
      "type": "array"
    },
    "error": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "properties": {
            "code": {
              "type": "string"
            },
            "message": {
              "type": "string"
            },
            "recoverable": {
              "type": "boolean"
            },
            "error_layer": {
              "type": "string"
            },
            "failure_kind": {
              "type": "string"
            },
            "failure_phase": {
              "type": "string",
              "enum": [
                "npi_init",
                "npi_load_design",
                "npi_fsdb_open"
              ]
            },
            "startup_reason": {
              "type": "string"
            },
            "native_error_summary": {
              "type": "string"
            },
            "diagnostic_log": {
              "type": "string",
              "enum": [
                "engine_npi_startup"
              ]
            },
            "advisories": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "code",
                  "severity",
                  "message"
                ],
                "properties": {
                  "code": {
                    "type": "string"
                  },
                  "severity": {
                    "type": "string"
                  },
                  "message": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "meta": {
      "type": "object"
    }
  },
  "additionalProperties": true,
  "description": "Open a design, waveform, or combined debug session.",
  "x-output_notes": "返回该 action 的 summary/data/error/meta；具体字段以 response schema 和 response example 为准。",
  "x-description-zh": "打开 design/waveform session。"
}
