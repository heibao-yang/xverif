{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.event.export.request.v1",
  "title": "event.export request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "event.export"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "aggregate": {
          "type": "object"
        },
        "clock": {
          "type": "string",
          "description": "采样、统计或协议检查使用的 clock 信号路径。"
        },
        "edge": {
          "type": "string",
          "description": "clock sampling 使用的边沿：posedge、negedge 或 dual。"
        },
        "events": {
          "type": "boolean"
        },
        "expr": {
          "type": "string",
          "description": "需要求值或匹配的布尔表达式。"
        },
        "group_by": {
          "type": "array"
        },
        "limit": {
          "type": "integer"
        },
        "max_events": {
          "type": "integer"
        },
        "max_examples": {
          "type": "integer"
        },
        "mode": {
          "type": "string"
        },
        "name": {
          "type": "string",
          "description": "已保存配置、游标、列表或接口配置名称。"
        },
        "rst_n": {
          "type": "string"
        },
        "sample_offset": {
          "type": "string",
          "description": "相对 clock edge 的采样偏移，默认 0ns。"
        },
        "scan_limit": {
          "type": "integer",
          "minimum": 1
        },
        "signals": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          ],
          "description": "信号列表，或 alias 到信号路径的映射。"
        },
        "time_range": {
          "type": "object",
          "description": "查询或分析的时间窗口。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "expr"
      ],
      "anyOf": [
        {
          "required": [
            "name"
          ]
        },
        {
          "required": [
            "clock",
            "signals"
          ]
        }
      ]
    },
    "limits": {
      "type": "object"
    },
    "output": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "event.export: 导出满足表达式的事件。",
  "x-purpose": "导出满足表达式的事件。",
  "x-how_it_works": "与 event.find 同样分析，但按 export 模式返回/写出更多命中数据；表达式支持布尔组合、相等比较和大小比较。",
  "x-when_to_use": "把事件列表交给后处理或报告。",
  "x-arg_contract_notes": "required: expr; also one of: name / clock + signals"
}
