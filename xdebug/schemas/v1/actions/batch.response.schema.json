{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.batch.response.v1",
  "title": "batch response",
  "type": "object",
  "required": [
    "api_version",
    "ok",
    "action",
    "summary",
    "data"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "ok": {
      "type": "boolean"
    },
    "action": {
      "type": "string",
      "enum": [
        "batch"
      ]
    },
    "summary": {
      "type": "object",
      "required": [
        "count",
        "all_ok",
        "failed_count",
        "failed_indexes",
        "failed_codes",
        "failed_layers"
      ],
      "properties": {
        "count": {
          "type": "integer",
          "minimum": 0
        },
        "all_ok": {
          "type": "boolean"
        },
        "failed_count": {
          "type": "integer",
          "minimum": 0
        },
        "failed_indexes": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "failed_codes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "failed_layers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "data": {
      "type": "object",
      "properties": {
        "results": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      },
      "additionalProperties": true
    },
    "findings": {
      "type": "array"
    },
    "warnings": {
      "type": "array"
    },
    "error": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "required": [
            "code",
            "message",
            "recoverable",
            "error_layer"
          ],
          "properties": {
            "code": {
              "type": "string"
            },
            "message": {
              "type": "string"
            },
            "recoverable": {
              "type": "boolean"
            },
            "error_layer": {
              "type": "string"
            }
          }
        }
      ]
    },
    "meta": {
      "type": "object"
    }
  },
  "additionalProperties": true,
  "description": "Execute multiple xdebug requests as one ordered batch.",
  "x-output_notes": "返回该 action 的 summary/data/error/meta；具体字段以 response schema 和 response example 为准。",
  "x-description-zh": "批量执行多个 xdebug request。"
}
