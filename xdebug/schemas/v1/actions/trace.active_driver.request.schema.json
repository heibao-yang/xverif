{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.trace.active_driver.request.v1",
  "title": "trace.active_driver request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "target",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "trace.active_driver"
      ]
    },
    "target": {
      "type": "object",
      "properties": {
        "daidir": {
          "type": "string"
        },
        "fsdb": {
          "type": "string"
        },
        "session_id": {
          "type": "string"
        }
      }
    },
    "args": {
      "type": "object",
      "properties": {
        "signal": {
          "type": "string",
          "description": "目标信号路径。"
        },
        "requested_time": {
          "type": "string",
          "description": "需要解释或追溯的目标时间点。"
        },
        "include_control": {
          "type": "boolean",
          "description": "Report control context (if/case) when no assignment confirmed (default true)"
        },
        "include_parity": {
          "type": "boolean",
          "description": "Run parity check: compare active trace vs static driver candidates"
        },
        "include_trace": {
          "type": "boolean",
          "description": "Return full data.trace with nodes, edges, selected_path (default false for compact)"
        },
        "include_alias_candidates": {
          "type": "boolean",
          "description": "Include alias_candidates even when a unique alias was resolved"
        },
        "include_compat_fields": {
          "type": "boolean",
          "description": "Return backward-compatible statements/path/active_values/requested_values fields"
        },
        "clock": {
          "type": "string"
        },
        "clk": {
          "type": "string"
        },
        "payload": {
          "type": "string"
        },
        "payloads": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "signals": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          ]
        },
        "index": {
          "oneOf": [
            {
              "type": "integer"
            },
            {
              "type": "string"
            }
          ]
        },
        "begin": {
          "type": "string"
        },
        "end": {
          "type": "string"
        },
        "start": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "output_file": {
          "type": "string"
        },
        "output_prefix": {
          "type": "string"
        },
        "sampling": {
          "type": "string"
        },
        "max_samples": {
          "type": "integer"
        },
        "max_events": {
          "type": "integer"
        },
        "max_findings": {
          "type": "integer"
        },
        "limit": {
          "type": "integer"
        },
        "rst_n": {
          "type": "string"
        },
        "edge": {
          "type": "string"
        },
        "format": {
          "type": "string"
        },
        "stream": {
          "type": "string"
        },
        "query": {
          "type": "object"
        },
        "streams": {
          "type": "array"
        },
        "config_path": {
          "type": "string"
        },
        "rc_path": {
          "type": "string"
        },
        "from_signal": {
          "type": "string"
        },
        "to_signal": {
          "type": "string"
        },
        "file": {
          "type": "string"
        },
        "line": {
          "type": "integer"
        },
        "expr": {
          "type": "string"
        },
        "scope": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "op": {
          "type": "string"
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "time_range": {
          "type": "object"
        },
        "time": {
          "type": "string"
        },
        "vld": {
          "type": "string"
        },
        "cnt": {
          "type": "string"
        },
        "requests": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "session_id": {
          "type": "string"
        },
        "valid": {
          "type": "string"
        },
        "ready": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "signal",
        "requested_time"
      ]
    },
    "limits": {
      "type": "object",
      "description": "Resource limits for the recursive active trace",
      "properties": {
        "max_depth": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum recursion depth through pass-through assignments and aliases (default 8)"
        },
        "max_nodes": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum number of trace nodes before truncation (default 50)"
        },
        "max_alias_candidates": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum number of alias candidates to explore (default 8)"
        },
        "max_trace_signals": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum signal count for value lookup (default 64)"
        }
      },
      "additionalProperties": false
    },
    "output": {
      "type": "object",
      "description": "Output format controls. verbosity=full|debug implies include_trace=true",
      "properties": {
        "format": {
          "type": "string",
          "enum": [
            "json",
            "xout"
          ]
        },
        "verbosity": {
          "type": "string",
          "enum": [
            "compact",
            "full",
            "debug"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "description": "trace.active_driver: 在指定时间找 active driver。",
  "x-purpose": "在指定时间找 active driver。",
  "x-how_it_works": "结合 waveform 当前值和 design 依赖，定位 requested_time 的有效驱动证据。",
  "x-when_to_use": "回答“此刻是谁真正驱动了它”。",
  "x-arg_contract_notes": "required: signal, requested_time"
}
