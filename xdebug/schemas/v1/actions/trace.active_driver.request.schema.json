{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.trace.active_driver.request.v1",
  "title": "trace.active_driver request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "trace.active_driver"
      ]
    },
    "target": {
      "type": "object",
      "properties": {
        "daidir": {
          "type": "string"
        },
        "fsdb": {
          "type": "string"
        },
        "session_id": {
          "type": "string"
        }
      }
    },
    "args": {
      "type": "object",
      "properties": {
        "limits": {
          "type": "object"
        },
        "signal": {
          "type": "string",
          "description": "目标信号路径。"
        },
        "time": {
          "type": "string",
          "description": "查询或验证的目标时间点。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "signal",
        "time"
      ]
    },
    "limits": {
      "type": "object",
      "description": "Resource limits for the recursive active trace",
      "properties": {
        "max_depth": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum recursion depth through pass-through assignments and aliases (default 8)"
        },
        "max_nodes": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum number of trace nodes before truncation (default 50)"
        },
        "max_alias_candidates": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum number of alias candidates to explore (default 8)"
        },
        "max_trace_signals": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum signal count for value lookup (default 64)"
        }
      },
      "additionalProperties": false
    },
    "output": {
      "type": "object",
      "description": "Output format controls. verbosity=full|debug does not restore legacy trace internals.",
      "properties": {
        "format": {
          "type": "string",
          "enum": [
            "json",
            "xout"
          ]
        },
        "verbosity": {
          "type": "string",
          "enum": [
            "compact",
            "full",
            "debug"
          ]
        }
      },
      "additionalProperties": false
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "trace.active_driver: 在指定时间找 active driver。",
  "x-purpose": "在指定时间找 active driver。",
  "x-how_it_works": "结合 waveform 当前值和 design 依赖，定位 time 的有效驱动证据。",
  "x-when_to_use": "回答“此刻是谁真正驱动了它”。",
  "x-arg_contract_notes": "required: signal, time"
}
