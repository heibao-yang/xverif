{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.axi.analysis.request.v1",
  "title": "axi.analysis request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "axi.analysis"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "analysis": {
          "type": "string",
          "enum": [
            "latency",
            "osd",
            "pending"
          ],
          "description": "Action-specific analysis input. Its type and accepted values are defined by this schema."
        },
        "direction": {
          "type": "string",
          "enum": [
            "write",
            "read",
            "all"
          ],
          "description": "Action-specific direction input. Its type and accepted values are defined by this schema."
        },
        "line_limit": {
          "type": "integer",
          "minimum": 1,
          "description": "Limits returned evidence rows only, not scanning, aggregation, or the verdict; read completeness fields as well."
        },
        "name": {
          "type": "string",
          "description": "Saved-object name in this action namespace; do not assume names are shared by cursors, lists, and protocol configs."
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ],
          "description": "Interprets only unitless time numbers; it never overrides a time string that already has a unit."
        }
      },
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "allOf": [
        {
          "anyOf": [
            {
              "required": [
                "analysis"
              ],
              "properties": {
                "analysis": {
                  "const": "pending"
                }
              }
            },
            {
              "not": {
                "required": [
                  "line_limit"
                ]
              }
            }
          ]
        }
      ]
    },
    "limits": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Analyze AXI latency, pending transactions, and outstanding activity.",
  "x-purpose": "汇总 AXI 行为。",
  "x-how_it_works": "analysis 取 latency、osd 或 pending，分别统计完成事务延迟、outstanding 变化和扫描结束未闭合事务。",
  "x-when_to_use": "快速判断 AXI 接口健康度。",
  "x-arg_contract_notes": "required: name",
  "x-description-zh": "汇总 AXI 行为。",
  "x-agent": {
    "use_when": [
      "汇总 AXI 行为。"
    ],
    "do_not_use_when": [
      "不要把本 action 用于 axi.export、axi.channel_stall 的业务目标；请改用列出的同域 action。"
    ],
    "alternatives": [
      {
        "action": "axi.export",
        "when": "导出 AXI 数据。"
      },
      {
        "action": "axi.channel_stall",
        "when": "实验性 AXI stall 分析。"
      }
    ],
    "constraints": [
      "required: name"
    ]
  }
}
