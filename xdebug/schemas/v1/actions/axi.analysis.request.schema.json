{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.axi.analysis.request.v1",
  "title": "axi.analysis request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "axi.analysis"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "analysis": {
          "type": "string",
          "enum": [
            "latency",
            "osd",
            "pending"
          ]
        },
        "direction": {
          "type": "string",
          "enum": [
            "write",
            "read",
            "all"
          ]
        },
        "line_limit": {
          "type": "integer",
          "minimum": 1,
          "description": "控制 response/xout 中 item、finding、event、transaction 或 row 的最大返回行数。"
        },
        "name": {
          "type": "string",
          "description": "已保存配置、游标、列表或接口配置名称。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "allOf": [
        {
          "anyOf": [
            {
              "required": [
                "analysis"
              ],
              "properties": {
                "analysis": {
                  "const": "pending"
                }
              }
            },
            {
              "not": {
                "required": [
                  "line_limit"
                ]
              }
            }
          ]
        }
      ]
    },
    "limits": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Analyze AXI latency, pending transactions, and outstanding activity.",
  "x-purpose": "汇总 AXI 行为。",
  "x-how_it_works": "analysis 取 latency、osd 或 pending，分别统计完成事务延迟、outstanding 变化和扫描结束未闭合事务。",
  "x-when_to_use": "快速判断 AXI 接口健康度。",
  "x-arg_contract_notes": "required: name",
  "x-description-zh": "汇总 AXI 行为。"
}
