{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.axi.analysis.request.v1",
  "title": "axi.analysis request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "axi.analysis"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "analysis": {
          "type": "string",
          "enum": [
            "latency",
            "osd",
            "outstanding"
          ]
        },
        "direction": {
          "type": "string",
          "enum": [
            "write",
            "read",
            "all"
          ]
        },
        "name": {
          "type": "string",
          "description": "已保存配置、游标、列表或接口配置名称。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "name"
      ]
    },
    "limits": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "axi.analysis: 汇总 AXI 行为。",
  "x-purpose": "汇总 AXI 行为。",
  "x-how_it_works": "基于 AXI 解析结果统计 channel、latency、stall 等。",
  "x-when_to_use": "快速判断 AXI 接口健康度。",
  "x-arg_contract_notes": "required: name"
}
