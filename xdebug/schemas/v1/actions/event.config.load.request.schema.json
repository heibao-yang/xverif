{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.event.config.load.request.v1",
  "title": "event.config.load request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "event.config.load"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "config_path": {
          "type": "string",
          "description": "Action-specific config_path input. Its type and accepted values are defined by this schema."
        },
        "name": {
          "type": "string",
          "description": "Saved-object name in this action namespace; do not assume names are shared by cursors, lists, and protocol configs."
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ],
          "description": "Interprets only unitless time numbers; it never overrides a time string that already has a unit."
        }
      },
      "additionalProperties": false,
      "required": [
        "name"
      ]
    },
    "limits": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Load an event-query configuration.",
  "x-purpose": "保存事件查询配置。",
  "x-how_it_works": "request args 只传 name 和可选 config_path/time_unit；clock/edge/sample_point/signals/reset 来自配置文件内容。",
  "x-when_to_use": "复用常见事件查询上下文。",
  "x-arg_contract_notes": "required: name",
  "x-description-zh": "保存事件查询配置。",
  "x-agent": {
    "use_when": [
      "保存事件查询配置。"
    ],
    "do_not_use_when": [
      "不要把本 action 用于 event.config.list、event.export 的业务目标；请改用列出的同域 action。"
    ],
    "alternatives": [
      {
        "action": "event.config.list",
        "when": "列出事件配置。"
      },
      {
        "action": "event.export",
        "when": "导出满足表达式的事件。"
      }
    ],
    "constraints": [
      "required: name"
    ]
  }
}
