{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.scope.list.request.v1",
  "title": "scope.list request",
  "type": "object",
  "required": [
    "api_version",
    "action"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "scope.list"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "max_depth": {
          "type": "integer"
        },
        "path": {
          "type": "string",
          "description": "Scope path to list. Empty string or '.' returns top-level scopes."
        },
        "recursive": {
          "type": "boolean"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false,
      "required": []
    },
    "limits": {
      "type": "object"
    },
    "output": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "scope.list: 列出 FSDB scope 或信号。",
  "x-purpose": "列出 FSDB scope 或信号。",
  "x-how_it_works": "从 waveform 数据库遍历 scope，按 path/recursive/max_depth 遍历或截断；无 scope 时列根层级。",
  "x-when_to_use": "帮助定位真实层次和信号路径。",
  "x-arg_contract_notes": "no required args"
}
