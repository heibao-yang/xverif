{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.cursor.list.request.v1",
  "title": "cursor.list request",
  "type": "object",
  "required": [
    "api_version",
    "action"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "cursor.list"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ],
          "description": "Interprets only unitless time numbers; it never overrides a time string that already has a unit."
        }
      },
      "additionalProperties": false,
      "required": []
    },
    "limits": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "List named waveform cursors.",
  "x-purpose": "列出游标。",
  "x-how_it_works": "读取当前 session 的 cursor 存储。",
  "x-when_to_use": "查看可复用的命名时间点。",
  "x-arg_contract_notes": "none",
  "x-description-zh": "列出游标。",
  "x-agent": {
    "use_when": [
      "列出游标。"
    ],
    "do_not_use_when": [
      "不要把本 action 用于 cursor.delete、cursor.get 的业务目标；请改用列出的同域 action。"
    ],
    "alternatives": [
      {
        "action": "cursor.delete",
        "when": "删除游标。"
      },
      {
        "action": "cursor.get",
        "when": "读取命名游标。"
      }
    ],
    "constraints": [
      "none"
    ]
  }
}
