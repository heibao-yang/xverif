{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.value.at.request.v1",
  "title": "value.at request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "value.at"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "at": {
          "type": "string"
        },
        "format": {
          "type": "string",
          "enum": [
            "h",
            "hex",
            "b",
            "bin",
            "binary",
            "d",
            "dec",
            "decimal",
            "array_indexed",
            "json",
            "tsv",
            "csv",
            "u64bin"
          ]
        },
        "signal": {
          "type": "string",
          "description": "目标信号路径。"
        },
        "slice_hint": {
          "type": "object"
        },
        "time": {
          "type": "string",
          "description": "查询或验证的目标时间点。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "signal",
        "time"
      ]
    },
    "limits": {
      "type": "object"
    },
    "output": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "value.at: 读取单个信号在指定时间的值。",
  "x-purpose": "读取单个信号在指定时间的值。",
  "x-how_it_works": "解析时间，定位 FSDB signal handle，读取该时刻值并格式化。",
  "x-when_to_use": "回答某个时间点信号是什么。",
  "x-arg_contract_notes": "required: signal, time"
}
