{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.session.doctor.request.v1",
  "title": "session.doctor request",
  "type": "object",
  "required": [
    "api_version",
    "action"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "session.doctor"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "目标 xdebug session 标识；session_id 的兼容别名。"
        },
        "name": {
          "type": "string",
          "description": "已保存配置、游标、列表或接口配置名称。"
        },
        "session_id": {
          "type": "string",
          "description": "目标 xdebug session 标识。"
        }
      },
      "additionalProperties": false,
      "required": []
    },
    "limits": {
      "type": "object"
    },
    "output": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "session.doctor: 诊断当前 session。",
  "x-purpose": "诊断当前 session。",
  "x-how_it_works": "检查 session 资源、路径和可访问状态。",
  "x-when_to_use": "定位 daidir/fsdb/session 绑定问题。",
  "x-arg_contract_notes": "none"
}
