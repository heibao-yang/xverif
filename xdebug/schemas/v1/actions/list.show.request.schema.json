{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.list.show.request.v1",
  "title": "list.show request",
  "type": "object",
  "required": [
    "api_version",
    "action"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "list.show"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Saved-object name in this action namespace; do not assume names are shared by cursors, lists, and protocol configs."
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ],
          "description": "Interprets only unitless time numbers; it never overrides a time string that already has a unit."
        }
      },
      "additionalProperties": false,
      "required": []
    },
    "limits": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Show the contents of a waveform signal list.",
  "x-purpose": "显示信号列表内容。",
  "x-how_it_works": "读取 ListManager 存储并返回 index/signal。",
  "x-when_to_use": "确认 list 当前包含哪些信号。",
  "x-arg_contract_notes": "none",
  "x-description-zh": "显示信号列表内容。",
  "x-agent": {
    "use_when": [
      "显示信号列表内容。"
    ],
    "do_not_use_when": [
      "不要把本 action 用于 list.add、list.create 的业务目标；请改用列出的同域 action。"
    ],
    "alternatives": [
      {
        "action": "list.add",
        "when": "向信号列表追加一个信号。"
      },
      {
        "action": "list.create",
        "when": "创建命名信号列表。"
      }
    ],
    "constraints": [
      "none"
    ]
  }
}
