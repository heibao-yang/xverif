{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.list.add.request.v1",
  "title": "list.add request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "list.add"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "已保存配置、游标、列表或接口配置名称。"
        },
        "signal": {
          "type": "string",
          "description": "目标信号路径。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "name",
        "signal"
      ]
    },
    "limits": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "list.add: 向信号列表追加一个信号。",
  "x-purpose": "向信号列表追加一个信号。",
  "x-how_it_works": "检查 signal 在 FSDB 中存在后写入 ListManager。",
  "x-when_to_use": "逐步构建观察列表。",
  "x-arg_contract_notes": "required: name, signal"
}
