{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.list.add.request.v1",
  "title": "list.add request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "list.add"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Saved-object name in this action namespace; do not assume names are shared by cursors, lists, and protocol configs."
        },
        "signal": {
          "type": "string",
          "description": "Final leaf signal path. Aggregate, array, and struct roots are not expanded automatically."
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ],
          "description": "Interprets only unitless time numbers; it never overrides a time string that already has a unit."
        }
      },
      "additionalProperties": false,
      "required": [
        "name",
        "signal"
      ]
    },
    "limits": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Add a signal to a named waveform list.",
  "x-purpose": "向信号列表追加一个信号。",
  "x-how_it_works": "检查 signal 在 FSDB 中存在后写入 ListManager。",
  "x-when_to_use": "逐步构建观察列表。",
  "x-arg_contract_notes": "required: name, signal",
  "x-description-zh": "向信号列表追加一个信号。",
  "x-agent": {
    "use_when": [
      "向信号列表追加一个信号。"
    ],
    "do_not_use_when": [
      "不要把本 action 用于 list.create、list.delete 的业务目标；请改用列出的同域 action。"
    ],
    "alternatives": [
      {
        "action": "list.create",
        "when": "创建命名信号列表。"
      },
      {
        "action": "list.delete",
        "when": "从信号列表删除信号或 index。"
      }
    ],
    "constraints": [
      "required: name, signal"
    ]
  }
}
