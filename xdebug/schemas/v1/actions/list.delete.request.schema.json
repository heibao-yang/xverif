{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.list.delete.request.v1",
  "title": "list.delete request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "list.delete"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "index": {
          "oneOf": [
            {
              "type": "integer"
            },
            {
              "type": "string"
            }
          ],
          "description": "列表中要删除的信号序号。"
        },
        "name": {
          "type": "string",
          "description": "已保存配置、游标、列表或接口配置名称。"
        },
        "signal": {
          "type": "string",
          "description": "目标信号路径。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "anyOf": [
        {
          "required": [
            "signal"
          ]
        },
        {
          "required": [
            "index"
          ]
        }
      ]
    },
    "limits": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Delete a signal or index from a waveform list.",
  "x-purpose": "从信号列表删除信号或 index。",
  "x-how_it_works": "按 name 找 list，再用 signal 或 index 删除条目。",
  "x-when_to_use": "维护已保存观察列表。",
  "x-arg_contract_notes": "required: name; also one of: signal / index",
  "x-description-zh": "从信号列表删除信号或 index。"
}
