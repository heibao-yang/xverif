{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.axi.export.response.v1",
  "title": "axi.export response",
  "type": "object",
  "required": [
    "api_version",
    "ok",
    "action",
    "summary",
    "data"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "ok": {
      "type": "boolean"
    },
    "action": {
      "type": "string",
      "enum": [
        "axi.export"
      ]
    },
    "summary": {
      "type": "object",
      "properties": {
        "output": {
          "type": "object",
          "properties": {
            "path": {"type": "string"},
            "write_path": {"type": "string"},
            "read_path": {"type": "string"},
            "meta_path": {"type": "string"},
            "file_format": {"type": "string", "enum": ["tsv", "csv"]}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "data": {
      "type": "object",
      "properties": {
        "output": {
          "type": "object",
          "properties": {
            "path": {"type": "string"},
            "write_path": {"type": "string"},
            "read_path": {"type": "string"},
            "meta_path": {"type": "string"},
            "file_format": {"type": "string", "enum": ["tsv", "csv"]}
          },
          "required": ["path", "write_path", "read_path", "meta_path", "file_format"],
          "additionalProperties": true
        }
      },
      "required": ["output"],
      "additionalProperties": true
    },
    "warnings": {
      "type": "array"
    },
    "error": {},
    "meta": {
      "type": "object"
    }
  },
  "additionalProperties": true,
  "description": "axi.export response: 导出 AXI 数据。",
  "x-output_notes": "返回该 action 的 summary/data/error/meta；具体字段以 response schema 和 response example 为准。"
}
