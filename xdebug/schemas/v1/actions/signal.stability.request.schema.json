{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.signal.stability.request.v1",
  "title": "signal.stability request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "signal.stability"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "conditions": {
          "type": "array",
          "items": {
            "type": "object"
          },
          "description": "需要验证的条件列表。"
        },
        "mode": {
          "type": "string"
        },
        "signal": {
          "type": "string",
          "description": "目标信号路径。"
        },
        "signals": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          ],
          "description": "信号列表，或 alias 到信号路径的映射。"
        },
        "time_range": {
          "type": "object",
          "properties": {
            "begin": {
              "type": "string"
            },
            "end": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "description": "查询或分析的时间窗口。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "signal"
      ]
    },
    "limits": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Check whether a signal stays stable in a time range.",
  "x-purpose": "检查信号窗口内是否稳定。",
  "x-how_it_works": "基于 signal.changes 判断是否只有初始值或无变化。",
  "x-when_to_use": "确认控制/状态信号是否保持不变。",
  "x-arg_contract_notes": "required: signal",
  "x-description-zh": "检查信号窗口内是否稳定。"
}
