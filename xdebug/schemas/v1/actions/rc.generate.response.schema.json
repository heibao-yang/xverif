    "request_id": {
      "type": "string"
    },
    "ok": {
      "type": "boolean"
    },
    "action": {
      "type": "string",
      "enum": [
        "rc.generate"
      ]
    },
    "summary": {
      "type": "object",
      "properties": {
        "config_path": {
          "type": "string"
        },
        "output": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "group_count": {
          "type": "integer"
        },
        "signal_count": {
          "type": "integer"
        },
        "expr_signal_count": {
          "type": "integer"
        },
        "marker_count": {
          "type": "integer"
        },
        "written": {
          "type": "boolean"
        },
        "valid": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "data": {
      "type": "object",
      "properties": {
        "config_path": {
          "type": "string"
        },
        "output": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "validation": {
          "type": "object"
        },
        "rc_preview": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "warnings": {
      "type": "array"
    },
    "error": {},
    "meta": {
      "type": "object"
    }
  },
  "additionalProperties": true,
  "description": "Generate a grouped waveform-view RC file.",
  "x-output_notes": "返回该 action 的 summary/data/error/meta；具体字段以 response schema 和 response example 为准。",
  "x-description-zh": "根据分组生成波形 rc。"
