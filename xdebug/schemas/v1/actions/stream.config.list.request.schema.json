{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.stream.config.list.request.v1",
  "title": "stream.config.list request",
  "type": "object",
  "required": [
    "api_version",
    "action"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "action": {
      "type": "string",
      "enum": [
        "stream.config.list"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "已保存配置、游标、列表或接口配置名称。"
        },
        "output": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string"
            },
            "file_format": {
              "type": "string"
            },
            "verbose": {
              "type": "boolean"
            }
          },
          "additionalProperties": false,
          "description": "导出配置对象；路径统一使用 output.path。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false,
      "required": []
    },
    "limits": {
      "type": "object"
    },
    "output": {
      "type": "object"
    },
    "request_id": {
      "type": "string"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "stream.config.list: 列出 stream 配置。",
  "x-purpose": "列出 stream 配置。",
  "x-how_it_works": "读取已保存 stream 定义；args:{} 列全部，args.name 显示单个配置详情。",
  "x-when_to_use": "查看可查询的 stream。",
  "x-arg_contract_notes": "args:{} list all; optional name shows one config"
}
