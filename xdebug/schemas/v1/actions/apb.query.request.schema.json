{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.apb.query.request.v1",
  "title": "apb.query request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "apb.query"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "addr": {
          "type": "string"
        },
        "address": {
          "type": "string"
        },
        "direction": {
          "type": "string",
          "enum": [
            "wr",
            "rd",
            "all"
          ]
        },
        "include_accesses": {
          "type": "boolean"
        },
        "last": {
          "type": "boolean"
        },
        "name": {
          "type": "string",
          "description": "已保存配置、游标、列表或接口配置名称。"
        },
        "num": {
          "type": "integer"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "name"
      ]
    },
    "limits": {
      "type": "object"
    },
    "output": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "apb.query: 查询 APB transfer。",
  "x-purpose": "查询 APB transfer。",
  "x-how_it_works": "按 APB 配置扫描 PSEL/PENABLE/PREADY 等握手和地址数据。",
  "x-when_to_use": "抽取 APB 读写访问。",
  "x-arg_contract_notes": "required: name"
}
