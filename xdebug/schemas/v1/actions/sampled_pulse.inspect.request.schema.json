{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.sampled_pulse.inspect.request.v1",
  "title": "sampled_pulse.inspect request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "sampled_pulse.inspect"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "clock": {
          "type": "string",
          "description": "采样、统计或协议检查使用的 clock 信号路径。"
        },
        "limit": {
          "type": "integer"
        },
        "max_events": {
          "type": "integer"
        },
        "max_findings": {
          "type": "integer"
        },
        "max_samples": {
          "type": "integer"
        },
        "payload": {
          "type": "string"
        },
        "payloads": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sampling": {
          "type": "string"
        },
        "time_range": {
          "type": "object",
          "description": "查询或分析的时间窗口。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        },
        "valid": {
          "type": "string",
          "description": "valid-ready 握手或采样检查中的 valid 信号路径。"
        }
      },
      "additionalProperties": false,
      "required": [
        "clock",
        "valid"
      ]
    },
    "limits": {
      "type": "object"
    },
    "output": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "sampled_pulse.inspect: 检查未被 clock 采到的 valid 短脉冲。",
  "x-purpose": "检查未被 clock 采到的 valid 短脉冲。",
  "x-how_it_works": "按 clock 采样 valid，同时扫描 valid 原始变化；若 valid 在两个采样边沿间拉高但没有采样边沿看到高电平，则报 unsampled_valid_pulse。可选 payload/payloads 用于补风险现场。",
  "x-when_to_use": "解释仿真里“波形有脉冲但 DUT 没采到”的问题。",
  "x-arg_contract_notes": "required: clock, valid"
}
