{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.actions.request.v1",
  "title": "actions request",
  "type": "object",
  "required": [
    "api_version",
    "action"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "actions"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "filter": {
          "type": "object",
          "properties": {
            "category": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": [
                  "builtin",
                  "design",
                  "waveform",
                  "combined",
                  "session"
                ]
              }
            },
            "requires": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": [
                  "none",
                  "design",
                  "waveform",
                  "combined",
                  "any",
                  "session"
                ]
              }
            },
            "purposes": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": [
                  "discover",
                  "configure",
                  "query",
                  "inspect",
                  "analyze",
                  "trace",
                  "verify",
                  "export",
                  "manage",
                  "transform",
                  "orchestrate"
                ]
              }
            },
            "keyword": {
              "type": "string",
              "pattern": ".*\\S.*"
            }
          },
          "additionalProperties": false
        },
        "output": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string"
            },
            "file_format": {
              "type": "string"
            },
            "verbose": {
              "type": "boolean"
            }
          },
          "additionalProperties": false,
          "description": "导出配置对象；路径统一使用 output.path。"
        }
      },
      "additionalProperties": false,
      "required": []
    },
    "limits": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "List the public xdebug action catalog.",
  "x-purpose": "列出当前运行时公开 action catalog。",
  "x-how_it_works": "默认返回 compact action names；args.output.verbose=true 时返回 descriptors，并同时返回 removed/modes。",
  "x-when_to_use": "让 agent 在调用前发现真实可用能力。",
  "x-arg_contract_notes": "no required args",
  "x-description-zh": "列出当前运行时公开 action catalog。"
}
