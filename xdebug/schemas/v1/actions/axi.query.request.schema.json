{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.axi.query.request.v1",
  "title": "axi.query request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "axi.query"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "addr": {
          "type": "string"
        },
        "address": {
          "type": "string"
        },
        "direction": {
          "type": "string",
          "enum": [
            "wr",
            "rd",
            "all"
          ]
        },
        "id": {
          "type": "string",
          "description": "目标 xdebug session 标识；session_id 的兼容别名。"
        },
        "include_transactions": {
          "type": "boolean"
        },
        "last": {
          "type": "boolean"
        },
        "name": {
          "type": "string",
          "description": "已保存配置、游标、列表或接口配置名称。"
        },
        "num": {
          "type": "integer"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "name"
      ]
    },
    "limits": {
      "type": "object"
    },
    "output": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "axi.query: 查询 AXI channel/transaction。",
  "x-purpose": "查询 AXI channel/transaction。",
  "x-how_it_works": "按 AXI 配置扫描 valid/ready 和 channel 字段。",
  "x-when_to_use": "抽取 AXI beat/transaction。",
  "x-arg_contract_notes": "required: name"
}
