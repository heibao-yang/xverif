{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.axi.query.request.v1",
  "title": "axi.query request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "axi.query"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "addr": {
          "type": "string"
        },
        "address": {
          "type": "string"
        },
        "direction": {
          "type": "string",
          "enum": [
            "write",
            "read"
          ]
        },
        "last": {
          "type": "boolean"
        },
        "name": {
          "type": "string",
          "description": "已保存配置、游标、列表或接口配置名称。"
        },
        "query": {
          "type": "object",
          "properties": {
            "line_limit": {
              "type": "integer",
              "minimum": 1
            },
            "index": {
              "type": "integer",
              "minimum": 1
            }
          },
          "additionalProperties": false,
          "description": "Protocol query controls; use 1-based query.index and query.line_limit; legacy args.num, args.limit, and query.limit are rejected."
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "name"
      ]
    },
    "limits": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "axi.query: 查询 AXI channel/transaction。",
  "x-purpose": "查询 AXI channel/transaction。",
  "x-how_it_works": "按 AXI 配置扫描 valid/ready 和 channel 字段；第 N 个 transaction 用 1-based query.index，多条用 query.line_limit。",
  "x-when_to_use": "抽取 AXI beat/transaction。",
  "x-arg_contract_notes": "required: name; use query.index / query.line_limit; do not use args.num, args.limit, or query.limit"
}
