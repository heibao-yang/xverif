{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.axi.query.request.v1",
  "title": "axi.query request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "axi.query"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "addr": {
          "type": "string"
        },
        "address": {
          "type": "string"
        },
        "direction": {
          "type": "string",
          "enum": [
            "write",
            "read"
          ]
        },
        "id": {
          "type": "string"
        },
        "last": {
          "type": "boolean"
        },
        "name": {
          "type": "string",
          "description": "已保存配置、游标、列表或接口配置名称。"
        },
        "output": {
          "type": "object",
          "properties": {
            "include_data": {
              "type": "boolean",
              "default": false
            }
          },
          "additionalProperties": false,
          "description": "AXI payload display controls; beat data is omitted unless include_data is true."
        },
        "query": {
          "oneOf": [
            {
              "type": "object",
              "properties": {
                "line_limit": {
                  "type": "integer",
                  "minimum": 1
                },
                "index": {
                  "type": "integer",
                  "minimum": 1
                }
              },
              "additionalProperties": false
            },
            {
              "type": "object",
              "required": [
                "channel",
                "handshake_time"
              ],
              "properties": {
                "channel": {
                  "type": "string",
                  "enum": [
                    "aw",
                    "w",
                    "b",
                    "ar",
                    "r"
                  ]
                },
                "handshake_time": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          ],
          "description": "Select transactions by 1-based index/line_limit, or exactly match an AXI channel handshake time."
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "allOf": [
        {
          "if": {
            "required": [
              "query"
            ],
            "properties": {
              "query": {
                "required": [
                  "channel"
                ]
              }
            }
          },
          "then": {
            "not": {
              "anyOf": [
                {
                  "required": [
                    "direction"
                  ]
                },
                {
                  "required": [
                    "address"
                  ]
                },
                {
                  "required": [
                    "addr"
                  ]
                },
                {
                  "required": [
                    "id"
                  ]
                },
                {
                  "required": [
                    "last"
                  ]
                }
              ]
            }
          }
        },
        {
          "not": {
            "required": [
              "address",
              "addr"
            ]
          }
        }
      ]
    },
    "limits": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "axi.query: 查询 AXI channel/transaction。",
  "x-purpose": "查询 AXI channel/transaction。",
  "x-how_it_works": "第 N 个 transaction 用 1-based query.index，多条用 query.line_limit；已知锚点时用 query.channel（AW/W/B/AR/R）与精确 query.handshake_time 反查。逐 beat payload 仅由 output.include_data 展开。",
  "x-when_to_use": "抽取 AXI beat/transaction 或从握手时间反查整笔事务。",
  "x-arg_contract_notes": "required: name; channel and handshake_time must appear together; do not mix handshake query with transaction selectors"
}
