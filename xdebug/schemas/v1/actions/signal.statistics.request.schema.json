{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.signal.statistics.request.v1",
  "title": "signal.statistics request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "signal.statistics"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "around": {
          "type": "string"
        },
        "at": {
          "type": "string"
        },
        "begin": {
          "type": "string",
          "description": "查询窗口起始时间。"
        },
        "clock": {
          "type": "string",
          "description": "采样、统计或协议检查使用的 clock 信号路径。"
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "object"
          },
          "description": "需要验证的条件列表。"
        },
        "edge": {
          "type": "string",
          "description": "clock sampling 使用的边沿：posedge、negedge 或 dual。"
        },
        "end": {
          "type": "string",
          "description": "查询窗口结束时间。"
        },
        "from": {
          "type": "string"
        },
        "limit": {
          "type": "integer"
        },
        "max_events": {
          "type": "integer"
        },
        "max_samples": {
          "type": "integer"
        },
        "mode": {
          "type": "string"
        },
        "sample_offset": {
          "type": "string",
          "description": "相对 clock edge 的采样偏移，默认 0ns。"
        },
        "signal": {
          "type": "string",
          "description": "目标信号路径。"
        },
        "signals": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          ],
          "description": "信号列表，或 alias 到信号路径的映射。"
        },
        "time_range": {
          "type": "object",
          "description": "查询或分析的时间窗口。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        },
        "to": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "signal"
      ]
    },
    "limits": {
      "type": "object"
    },
    "output": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "signal.statistics: 统计信号活动。",
  "x-purpose": "统计信号活动。",
  "x-how_it_works": "无 clock 时统计原始变化；有 clock 时按边沿采样，统计 known/high/low/unknown。",
  "x-when_to_use": "量化活跃度、占空和采样质量。",
  "x-arg_contract_notes": "required: signal"
}
