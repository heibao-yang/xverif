{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.rc.generate.request.v1",
  "title": "rc.generate request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "rc.generate"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "config_path": {
          "type": "string",
          "description": "输入配置文件路径。"
        },
        "output": {
          "type": "object",
          "required": [
            "path"
          ],
          "properties": {
            "path": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "description": "导出配置对象；路径统一使用 output.path。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "required": [
        "config_path",
        "output"
      ],
      "additionalProperties": false
    },
    "limits": {
      "type": "object"
    },
    "output": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "rc.generate: 根据分组生成波形 rc。",
  "x-purpose": "根据分组生成波形 rc。",
  "x-how_it_works": "读取配置并写出 output.path，返回 group/signal 统计。",
  "x-when_to_use": "把调试信号集合导入波形工具。",
  "x-arg_contract_notes": "required: config_path, output"
}
