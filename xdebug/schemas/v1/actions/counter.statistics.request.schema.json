{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.counter.statistics.request.v1",
  "title": "counter.statistics request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "counter.statistics"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "required": [
        "clock",
        "time_range",
        "vld",
        "cnt"
      ],
      "properties": {
        "clock": {
          "type": "string",
          "description": "采样、统计或协议检查使用的 clock 信号路径。"
        },
        "cnt": {
          "type": "string",
          "description": "计数器统计使用的 counter 信号路径。"
        },
        "edge": {
          "type": "string",
          "description": "clock sampling 使用的边沿：posedge、negedge 或 dual。"
        },
        "line_limit": {
          "type": "integer",
          "minimum": 1,
          "description": "控制 response/xout 中 item、finding、event、transaction 或 row 的最大返回行数。"
        },
        "max_samples": {
          "type": "integer",
          "minimum": 1
        },
        "sample_point": {
          "type": "string",
          "enum": [
            "before",
            "after"
          ],
          "description": "posedge/dual 时的采样点：before 或 after；posedge 默认推荐 before。"
        },
        "time_range": {
          "type": "object",
          "properties": {
            "begin": {
              "type": "string"
            },
            "end": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "description": "查询或分析的时间窗口。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        },
        "vld": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "object"
            }
          ],
          "description": "计数器统计使用的 valid 信号路径。"
        }
      },
      "additionalProperties": false
    },
    "limits": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Analyze sampled counter behavior and statistics.",
  "x-purpose": "统计计数器行为。",
  "x-how_it_works": "按 clock/vld/cnt 采样，分析递增、回绕、停顿和异常。",
  "x-when_to_use": "判断计数器是否符合预期。",
  "x-arg_contract_notes": "required: clock, time_range, vld, cnt",
  "x-description-zh": "统计计数器行为。"
}
