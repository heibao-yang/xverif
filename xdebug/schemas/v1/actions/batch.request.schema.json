{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.batch.request.v1",
  "title": "batch request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "batch"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string"
        },
        "requests": {
          "type": "array",
          "items": {
            "type": "object"
          },
          "description": "batch action 中按顺序执行的 request 列表。"
        }
      },
      "additionalProperties": false,
      "required": [
        "requests"
      ]
    },
    "limits": {
      "type": "object"
    },
    "output": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "batch: 批量执行多个 xdebug request。",
  "x-purpose": "批量执行多个 xdebug request。",
  "x-how_it_works": "按 requests 顺序复用同一入口逐条调度，汇总每条响应。",
  "x-when_to_use": "减少多轮 IPC 和保持一组查询的上下文一致。",
  "x-arg_contract_notes": "required: requests"
}
