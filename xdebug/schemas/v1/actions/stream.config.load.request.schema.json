{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.stream.config.load.request.v1",
  "title": "stream.config.load request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "action": {
      "type": "string",
      "enum": [
        "stream.config.load"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string"
        },
        "streams": {
          "type": "array",
          "description": "需要加载的 stream 配置列表。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "streams"
      ]
    },
    "limits": {
      "type": "object"
    },
    "output": {
      "type": "object"
    },
    "request_id": {
      "type": "string"
    },
    "auth_token": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "stream.config.load: 加载 stream 配置。",
  "x-purpose": "加载 stream 配置。",
  "x-how_it_works": "把 stream 定义写入 stream manager。",
  "x-when_to_use": "定义 valid/ready/data 类流接口。",
  "x-arg_contract_notes": "required: streams"
}
