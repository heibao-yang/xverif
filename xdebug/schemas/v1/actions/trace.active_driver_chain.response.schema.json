{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.trace.active_driver_chain.response.v1",
  "title": "trace.active_driver_chain response",
  "type": "object",
  "required": [
    "api_version",
    "ok",
    "action",
    "summary",
    "data"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "ok": {
      "type": "boolean"
    },
    "action": {
      "type": "string",
      "enum": [
        "trace.active_driver_chain"
      ]
    },
    "tool": {
      "type": "object"
    },
    "session": {
      "type": [
        "object",
        "null"
      ]
    },
    "summary": {
      "type": "object",
      "required": [
        "signal",
        "time",
        "hop_count",
        "termination",
        "truncated"
      ],
      "properties": {
        "signal": {
          "type": "string"
        },
        "time": {
          "type": "string"
        },
        "hop_count": {
          "type": "integer",
          "minimum": 0
        },
        "termination": {
          "type": "string"
        },
        "truncated": {
          "type": "boolean"
        },
        "limit_hint": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "data": {
      "type": "object",
      "required": [
        "hops"
      ],
      "properties": {
        "summary": {
          "type": "object"
        },
        "hops": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/hop"
          }
        },
        "truncated": {
          "type": "boolean"
        },
        "common_blocks": {
          "type": "array"
        }
      },
      "additionalProperties": false
    },
    "error": {},
    "meta": {
      "type": "object"
    }
  },
  "$defs": {
    "hop": {
      "allOf": [
        {
          "$ref": "#/$defs/source_path"
        },
        {
          "type": "object",
          "required": [
            "index"
          ],
          "properties": {
            "index": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      ]
    },
    "source_path": {
      "type": "object",
      "required": [
        "file",
        "line",
        "source_context",
        "signal_path"
      ],
      "properties": {
        "file": {
          "type": "string"
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "source_context": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "line",
              "text",
              "active"
            ],
            "properties": {
              "line": {
                "type": "integer",
                "minimum": 1
              },
              "text": {
                "type": "string"
              },
              "active": {
                "type": "boolean"
              }
            },
            "additionalProperties": false
          }
        },
        "signal_path": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "additionalProperties": true,
  "description": "trace.active_driver_chain response: 展开 active driver 链。",
  "x-output_notes": "返回该 action 的 summary/data/error/meta；具体字段以 response schema 和 response example 为准。"
}
