{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.event.find.request.v1",
  "title": "event.find request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "event.find"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "aggregate": {
          "type": "object"
        },
        "clock": {
          "type": "string",
          "description": "采样、统计或协议检查使用的 clock 信号路径。"
        },
        "edge": {
          "type": "string",
          "description": "clock sampling 使用的边沿：posedge、negedge 或 dual。"
        },
        "events": {
          "type": "boolean"
        },
        "expr": {
          "type": "string",
          "description": "需要求值或匹配的布尔表达式。"
        },
        "group_by": {
          "type": "array"
        },
        "line_limit": {
          "type": "integer",
          "minimum": 1,
          "description": "控制 response/xout 中 item、finding、event、transaction 或 row 的最大返回行数。"
        },
        "max_samples": {
          "type": "integer",
          "minimum": 1
        },
        "mode": {
          "type": "string",
          "enum": [
            "first",
            "last",
            "all"
          ],
          "default": "first"
        },
        "name": {
          "type": "string",
          "description": "已保存配置、游标、列表或接口配置名称。"
        },
        "rst_n": {
          "type": "string"
        },
        "sample_point": {
          "type": "string",
          "enum": [
            "before",
            "after"
          ],
          "description": "posedge/dual 时的采样点：before 或 after；posedge 默认推荐 before。"
        },
        "signals": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          ],
          "description": "信号列表，或 alias 到信号路径的映射。"
        },
        "time_range": {
          "type": "object",
          "properties": {
            "begin": {
              "type": "string"
            },
            "end": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "description": "查询或分析的时间窗口。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "expr"
      ],
      "anyOf": [
        {
          "required": [
            "name"
          ]
        },
        {
          "required": [
            "clock",
            "signals"
          ]
        }
      ],
      "allOf": [
        {
          "anyOf": [
            {
              "required": [
                "mode"
              ],
              "properties": {
                "mode": {
                  "const": "all"
                }
              }
            },
            {
              "not": {
                "required": [
                  "line_limit"
                ]
              }
            }
          ]
        }
      ]
    },
    "limits": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Find sampled events that match an expression.",
  "x-purpose": "查找满足表达式的事件样例。",
  "x-how_it_works": "用 name 配置或 inline clock/signals 构建 EventQuery，按 clock sampling 模式扫描表达式命中；表达式支持布尔组合、相等比较和大小比较。",
  "x-when_to_use": "快速找到协议条件发生的时间。",
  "x-arg_contract_notes": "required: expr; also one of: name / clock + signals",
  "x-description-zh": "查找满足表达式的事件样例。"
}
