{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.axi.latency_outlier.request.v1",
  "title": "axi.latency_outlier request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "axi.latency_outlier"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "line_limit": {
          "type": "integer",
          "minimum": 1,
          "description": "控制 response/xout 中 item、finding、event、transaction 或 row 的最大返回行数。"
        },
        "direction": {
          "type": "string",
          "enum": ["write", "read", "all"]
        },
        "method": {
          "type": "string",
          "enum": ["top_n", "threshold"],
          "default": "top_n",
          "description": "top_n 返回完整候选集中的最慢事务排名；threshold 返回超过阈值的事务。"
        },
        "top_n": {
          "type": "integer",
          "minimum": 1,
          "default": 10,
          "description": "method=top_n 时，从完整候选集选择的最慢事务数量。"
        },
        "threshold": {
          "type": "string",
          "description": "method=threshold 时必填的延迟阈值，例如 100ns。"
        },
        "name": {
          "type": "string",
          "description": "已保存配置、游标、列表或接口配置名称。"
        },
        "output": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string"
            },
            "file_format": {
              "type": "string"
            },
            "verbose": {
              "type": "boolean"
            }
          },
          "additionalProperties": false,
          "description": "导出配置对象；路径统一使用 output.path。"
        },
        "time_range": {
          "type": "object",
          "properties": {
            "begin": {
              "type": "string"
            },
            "end": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "description": "查询或分析的时间窗口。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "name"
      ]
    },
    "limits": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "axi.latency_outlier: 实验性 AXI latency 异常。",
  "x-purpose": "实验性 AXI latency 异常。",
  "x-how_it_works": "从配对结果中找超过阈值或分布异常的事务。",
  "x-when_to_use": "定位慢事务。",
  "x-arg_contract_notes": "required: name"
}
