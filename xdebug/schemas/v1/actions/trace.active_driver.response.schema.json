{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.trace.active_driver.response.v1",
  "title": "trace.active_driver response",
  "type": "object",
  "required": [
    "api_version",
    "ok",
    "action",
    "summary",
    "data"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "ok": {
      "type": "boolean"
    },
    "action": {
      "type": "string",
      "enum": [
        "trace.active_driver"
      ]
    },
    "tool": {
      "type": "object"
    },
    "session": {
      "type": [
        "object",
        "null"
      ]
    },
    "summary": {
      "type": "object",
      "required": [
        "signal",
        "time",
        "active_time",
        "path_count",
        "truncated"
      ],
      "properties": {
        "signal": {
          "type": "string"
        },
        "time": {
          "type": "string"
        },
        "active_time": {
          "type": "string"
        },
        "requested_time": {
          "type": "string"
        },
        "driver_last_change_time": {
          "type": "string"
        },
        "time_semantics": {
          "type": "object"
        },
        "driver_status": {
          "type": "string"
        },
        "termination": {
          "type": "string"
        },
        "termination_detail": {
          "type": "string"
        },
        "evidence_scope": {
          "type": "string"
        },
        "evidence_status": {
          "type": "string"
        },
        "evidence_source": {
          "type": [
            "string",
            "null"
          ]
        },
        "static_candidate_count": {
          "type": "integer",
          "minimum": 0
        },
        "active_check_count": {
          "type": "integer",
          "minimum": 0
        },
        "trace_node_count": {
          "type": "integer",
          "minimum": 0
        },
        "path_count": {
          "type": "integer",
          "minimum": 0
        },
        "truncated": {
          "type": "boolean"
        },
        "limit_hint": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "data": {
      "type": "object",
      "required": [
        "paths"
      ],
      "properties": {
        "summary": {
          "type": "object"
        },
        "paths": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_path"
          }
        },
        "truncated": {
          "type": "boolean"
        },
        "common_blocks": {
          "type": "array"
        }
      },
      "additionalProperties": true
    },
    "error": {},
    "meta": {
      "type": "object"
    }
  },
  "$defs": {
    "source_path": {
      "type": "object",
      "required": [
        "file",
        "line",
        "source_context",
        "signal_path"
      ],
      "properties": {
        "file": {
          "type": "string"
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "source_context": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "line",
              "text",
              "active"
            ],
            "properties": {
              "line": {
                "type": "integer",
                "minimum": 1
              },
              "text": {
                "type": "string"
              },
              "active": {
                "type": "boolean"
              }
            },
            "additionalProperties": false
          }
        },
        "signal_path": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true,
  "description": "Find active driver evidence at a specific waveform time.",
  "x-output_notes": "返回该 action 的 summary/data/error/meta；具体字段以 response schema 和 response example 为准。",
  "x-description-zh": "在指定时间找 active driver。"
}
