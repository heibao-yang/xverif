{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.list.diff.request.v1",
  "title": "list.diff request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "list.diff"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "begin": {
          "type": "string",
          "description": "查询窗口起始时间。"
        },
        "end": {
          "type": "string",
          "description": "查询窗口结束时间。"
        },
        "name": {
          "type": "string",
          "description": "已保存配置、游标、列表或接口配置名称。"
        },
        "time_unit": {
          "type": "string",
