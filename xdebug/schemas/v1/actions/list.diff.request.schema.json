{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.list.diff.request.v1",
  "title": "list.diff request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "list.diff"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "已保存配置、游标、列表或接口配置名称。"
        },
        "time_range": {
          "type": "object",
          "properties": {
            "begin": {
              "type": "string"
            },
            "end": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "description": "查询或分析的时间窗口。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        },
        "value_format": {
          "type": "string",
          "enum": [
            "hex",
            "bin",
            "dec"
          ],
          "description": "仅控制响应中信号值的显示格式；不影响采样、时间或导出文件格式。"
        }
      },
      "additionalProperties": false,
      "required": [
        "name",
        "time_range"
      ]
    },
    "limits": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Find the first difference in a waveform list over a time range.",
  "x-purpose": "查找 list 在时间窗口内的首次差异。",
  "x-how_it_works": "解析 time_range.begin/end 后扫描 list 内信号变化。",
  "x-when_to_use": "定位一组信号何时开始不同。",
  "x-arg_contract_notes": "required: name, time_range",
  "x-description-zh": "查找 list 在时间窗口内的首次差异。"
}
