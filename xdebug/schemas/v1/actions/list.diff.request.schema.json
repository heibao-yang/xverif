            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "name",
        "begin",
        "end"
      ]
    },
    "limits": {
      "type": "object"
    },
    "output": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "list.diff: 查找 list 在两个时间点之间的首次差异。",
  "x-purpose": "查找 list 在两个时间点之间的首次差异。",
  "x-how_it_works": "解析 begin/end 后扫描 list 内信号变化。",
  "x-when_to_use": "定位一组信号何时开始不同。",
  "x-arg_contract_notes": "required: name, begin, end"
}
