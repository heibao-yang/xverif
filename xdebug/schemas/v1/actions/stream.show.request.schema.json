{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.stream.show.request.v1",
  "title": "stream.show request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "action": {
      "type": "string",
      "enum": [
        "stream.show"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "required": [
        "stream"
      ],
      "properties": {
        "stream": {
          "type": "string",
          "description": "Action-specific stream input. Its type and accepted values are defined by this schema."
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ],
          "description": "Interprets only unitless time numbers; it never overrides a time string that already has a unit."
        }
      },
      "additionalProperties": false
    },
    "limits": {
      "type": "object"
    },
    "request_id": {
      "type": "string"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Show a stream definition and its resolved signal metadata.",
  "x-purpose": "显示 stream 定义和摘要。",
  "x-how_it_works": "按 stream 名读取配置并返回字段。",
  "x-when_to_use": "确认 stream 绑定了哪些信号。",
  "x-arg_contract_notes": "required: stream",
  "x-description-zh": "显示 stream 定义和摘要。",
  "x-agent": {
    "use_when": [
      "显示 stream 定义和摘要。"
    ],
    "do_not_use_when": [
      "不要把本 action 用于 stream.config.load、stream.config.list 的业务目标；请改用列出的同域 action。"
    ],
    "alternatives": [
      {
        "action": "stream.config.load",
        "when": "加载 stream 配置。"
      },
      {
        "action": "stream.config.list",
        "when": "列出 stream 配置。"
      }
    ],
    "constraints": [
      "required: stream"
    ]
  }
}
