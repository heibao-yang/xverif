{
  "api_version": "xdebug.v1",
  "action": "stream.config.load",
  "target": {
    "session_id": "wave0"
  },
  "args": {
    "mode": "replace",
    "streams": [
      {
        "name": "req_stream",
        "signals": {
          "clk": "top.clk",
          "rst_n": "top.rst_n",
          "req_vld": "top.req_vld",
          "req_rdy": "top.req_rdy",
          "req_sop": "top.req_sop",
          "req_eop": "top.req_eop",
          "req_data": "top.req_data",
          "addr_hi": "top.addr_hi",
          "addr_lo": "top.addr_lo",
          "req_cmd": "top.req_cmd"
        },
        "clock": "clk",
        "edge": "posedge",
        "reset": "!rst_n",
        "vld": "req_vld",
        "rdy": "req_rdy",
        "sop": "req_sop",
        "eop": "req_eop",
        "data_fields": {
          "opcode": "req_data[7:0]",
          "addr": "{addr_hi, addr_lo}",
          "is_wr": "req_cmd == 2'b01"
        }
      }
    ]
  }
}
