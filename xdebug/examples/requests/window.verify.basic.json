{
  "api_version": "xdebug.v1",
  "action": "window.verify",
  "target": {
    "session_id": "case_a"
  },
  "args": {
    "clock": "top.u.clk",
    "conditions": [
      {
        "expr": "valid == 1",
        "signals": {
          "valid": "top.u.valid"
        },
        "mode": "always"
      }
    ],
    "time_range": {
      "begin": "0ns",
      "end": "1us"
    }
  }
}
